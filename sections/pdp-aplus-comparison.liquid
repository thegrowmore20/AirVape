<style>
	.aplus-v2.desktop {
		min-width: 800px;
		margin-left: auto;
		margin-right: auto;
		word-wrap: break-word;
		overflow-wrap: break-word;
		word-break: break-word;
	}
	.aplus-v2 .aplus-container-3 {
		padding: 40px 0 0;
	}
	.aplus-v2 .premium-aplus .aplus-h1 {
		font-size: 32px;
		line-height: 1.2em;
		font-weight: 500;
	}
	.aplus-v2 .premium-aplus-module-5 .table-container {
		position: relative;
		opacity: 1;
	}
	.aplus-v2 .premium-aplus-module-5 .table-slider {
		overflow-x: auto;
		overflow-y: visible;
		width: 100%;
		border-radius: 8px;
		cursor: grab;
		user-select: none;
		-webkit-user-select: none;
		scroll-behavior: auto;
	}
	
	.aplus-v2 .premium-aplus-module-5 .table-slider.is-dragging {
		cursor: grabbing;
	}
	
	.aplus-v2 .premium-aplus-module-5 .table-slider.is-dragging * {
		cursor: grabbing !important;
	}
	
	.aplus-v2 .premium-aplus-module-5 .table-slider table,
	.aplus-v2 .premium-aplus-module-5 .table-slider td,
	.aplus-v2 .premium-aplus-module-5 .table-slider th {
		user-select: none;
		-webkit-user-select: none;
	}
	
	@media (max-width: 768px) {
		.aplus-v2 .premium-aplus-module-5 .table-slider {
			cursor: auto;
		}
	}
	.aplus-v2 .premium-aplus-module-5 table.a-bordered {
		border-width: 0px;
		border-color: #d5d9d9;
		border-style: solid;
		border-radius: 8px;
		margin-left: auto;
		margin-right: auto;
	}
	.aplus-v2 .premium-aplus-module-5 table.a-bordered tr:last-child {
		border-bottom-left-radius: 8px;
		border-bottom-right-radius: 8px;
	}
	.aplus-v2 .premium-aplus-module-5 table.a-bordered tr:last-child td {
		{% comment %} border-bottom: 0; {% endcomment %}
	}
	.aplus-v2 .premium-aplus-module-5 table.a-bordered tr:last-child td:first-child {
		border-bottom-left-radius: 8px;
	}
	.aplus-v2 .premium-aplus-module-5 table.a-bordered tr:last-child td:last-child {
		border-bottom-right-radius: 8px;
	}
	th.aplus-data-column.top-header {
		border: 0;
	}
	td.attribute.a-text-bold.column-cell-1 {
		border-top-left-radius: 8px;
	}
	tr.first-content-row td:last-child {
		border-top-right-radius: 8px;
	}
	.aplus-v2 .premium-aplus-module-5 .scroll-width {
		overflow-x: scroll;
		overflow-y: visible;
	}
	table.a-bordered {
		border-start-start-radius: var(--__TxpmBlwIJ, .5rem);
		border-start-end-radius: var(--__TxpmBlwIJ, .5rem);
		border-end-start-radius: var(--__TxpmBlwIJ, .5rem);
		border-end-end-radius: var(--__TxpmBlwIJ, .5rem);
		border-width: var(--__TxpzNygdu, .0625rem);
		margin-bottom: 22px;
		border-style: solid;
		border-color: var(--__dChNmAmGoMXsTxp, #d5d9d9);
		border-collapse: separate;
		border-spacing: 0;
		overflow: hidden;
	}
	td, th {
		padding: .1875rem;
		vertical-align: top;
	}
	table.a-bordered td, table.a-bordered th {
		border-bottom: 1px solid #d5d9d9;
		border-right: 1px solid #d5d9d9;
		border-color: #dfd9d9;
		padding-block-start: 8px;
		padding-inline-start: .75rem;
		padding-inline-end: .75rem;
		padding-block-end: 8px;
		background-color: var(--__dChNmAmGoMXsPxT, #fff);
	}
	.aplus-v2 .premium-aplus-module-5 table.a-bordered td, .aplus-v2 .premium-aplus-module-5 table.a-bordered th {
		background-color: #fff;
		vertical-align: middle;
	}
	
	.aplus-v2 .premium-aplus-module-5 table.a-bordered th.second-sticky-column {
		border: 1px solid #d5d9d9;
		border-bottom: 0;
		border-top-left-radius: 12px;
		border-top-right-radius: 12px;
	}
	
	.aplus-v2 .premium-aplus-module-5 td.attribute.empty {
		height: 300px;
		border-top-left-radius: 8px;
		border: 0;
	}
	tr.first-content-row td {
		border-top: 1px solid #d5d9d9;
	}
	.aplus-v2 .premium-aplus-module-5.enso-comparison td.attribute.empty {
		height: 250px;
	}
	td.aplus-data-column.secondary-content-column:last-of-type,
	th.aplus-data-column.top-header:last-child {
		{% comment %} border-right: 0; {% endcomment %}
	}
	th.aplus-data-column.top-header:last-child {
		border-top-right-radius: 8px;
	}
	.aplus-v2 .premium-aplus-module-5 .attribute, .aplus-v2 .premium-aplus-module-5 .active-item {
		position: sticky;
	}
	.aplus-v2 .premium-aplus-module-5 td.attribute {
		min-width: 230px;
		top: auto;
		left: 0;
		z-index: 100;
	}
	.aplus-v2 .premium-aplus-module-5 td.attribute:not(.empty) {
		background-color: #f8f8f8;
		border-left: 1px solid #d5d9d9;
	}
	
	.aplus-v2 .premium-aplus-module-5 table.a-bordered td, .aplus-v2 .premium-aplus-module-5 table.a-bordered th {
		background-color: #fff;
	}
	.aplus-v2 .aplus-review-right-padding {
		padding-right: 0.1rem;
	}
	
	.aplus-v2 .premium-aplus-module-5 td.active-item, 
	.aplus-v2 .premium-aplus-module-5 th.active-item {
		top: auto;
		left: 230px;
		z-index: 100;
	}
	.comparison-metric-name {
		font-weight: 600;
		font-size: 14px;
	}
	td.aplus-data-column {
		font-size: 14px;
		text-align: center;
		padding: 9px !important;
	}
	.comparison-product-card .product-card {
		border: 0;
		padding: 0;
	}
	.comparison-product-card .custom-wishlist-button,
	.comparison-product-card .product-badges-container,
	.comparison-product-card .mt-4.empty\:hidden {
		display: none
	}
	.comparison-product-card .group\/media:hover .group-hover\/media\:opacity-100 {
		opacity: 0;
	}
	.comparison-product-card .product-card:hover {
		transform: translateY(0)
	}
	.comparison-product-card h2.product-name {
		-webkit-line-clamp: 1;
		min-height: 25px;
		font-size: 14px;
	}
	.comparison-product-card .add-to-cart-span {
		font-size: 14px;
	}
	.enso-comparison .comparison-product-card quick-add-button,
	.enso-comparison .comparison-product-card .product-card__info {
		display: none;
	}
	
	.enso-comparison .comparison-product-card .product-card-media.media.rounded-block {
		padding-bottom: 0;
	}
	td.aplus-data-column.active.active-item.second-sticky-column,
	th.aplus-data-column.top-header,
	td.aplus-data-column.secondary-content-column {
		max-width: 230px;
		width: 230px;
		min-width: 230px;
	}
	@media (max-width: 992px) {
		[data-aplus-section-container] {
			padding: 0;
		}
		.aplus-v2.desktop {
			min-width: 100%;
		}
		.aplus-v2 .premium-aplus-module-5 td.attribute {
			min-width: 170px;
			left: -1px;
		}
		.aplus-v2 .premium-aplus-module-5 td.active-item, 
		.aplus-v2 .premium-aplus-module-5 th.active-item {
			left: 169px;
			z-index: 3;
		}
		.comparison-product-card quick-add-button button {
			padding-left: 24px;
			padding-right: 24px;
		}
	}
	
	/* mobile design */
	@media (max-width: 768px){
		.aplus-v2 .premium-aplus-module-5 table.a-bordered {
			width: 100%;
		}
		td.aplus-data-column.active.active-item.second-sticky-column {
			left: 0;
			text-align: left;
			display: inline-flex;
			height: 85px;
			align-items: end;
		}
		td.attribute.empty.first-sticky-column,
		.aplus-v2 .premium-aplus-module-5.enso-comparison td.attribute.empty {
			display: none !important;
		}
		td.aplus-data-column.secondary-content-column {
			vertical-align: bottom;
		}
		.aplus-v2 .premium-aplus-module-5 td.active-item, .aplus-v2 .premium-aplus-module-5 th.active-item {
			left: 0px;
			z-index: 3;
			position: relative;
		}
		.aplus-v2 .premium-aplus-module-5 td.attribute {
			min-width: 170px;
			left: -1px;
			position: absolute;
			background: transparent;
			background-color: transparent !important;
			height: 85px;
			pointer-events: none;
		}
		td.aplus-data-column.active.active-item.second-sticky-column {
			left: 0;
			text-align: left;
			display: inline-flex;
			height: 85px;
			align-items: end;
		}
		table.a-bordered td, table.a-bordered th {
			border-right: 0;
		}
		.aplus-v2 .premium-aplus-module-5 table.a-bordered td,
		.aplus-v2 .premium-aplus-module-5 table.a-bordered th {
			vertical-align: bottom;
		}
		td.aplus-data-column.active.active-item.second-sticky-column, th.aplus-data-column.top-header, td.aplus-data-column.secondary-content-column {
			max-width: 200px;
			width: 200px;
			min-width: 200px;
		}
	}
</style>

{% liquid
	assign selected_features = product.metafields.custom.comparison_features.value
	assign compare_products = product.metafields.custom.comparison_products.value
	
	assign current_compare_key = product.metafields.custom.compare_key.value
	if current_compare_key == blank
	assign current_compare_key = product.handle | replace: '-', '_'
	endif
%}


<div data-aplus-section-container {% render 'section-attrs' %}>
	<div class="aplus-v2 desktop">
		
		{% liquid
			assign selected_features = product.metafields.custom.comparison_features.value
			assign compare_products = product.metafields.custom.comparison_products.value
			
			assign current_compare_key = product.metafields.custom.compare_key.value
			if current_compare_key == blank
			assign current_compare_key = product.handle | replace: '-', '_'
			endif
		%}
		
		{% if selected_features != blank and compare_products != blank %}
			<div class="comparison-table-wrap" style="display: none;">
				<table class="comparison-table">
					<tbody>
						<tr>
							<th class="comparison-table__feature-col">Feature</th>
							
							{%- comment -%} Current product column {%- endcomment -%}
							<th class="comparison-table__product-col">
								<div class="comparison-product-card">
									{% if product.featured_image %}
										{{
											product.featured_image
											| image_url: width: 300
											| image_tag: loading: 'lazy', widths: '150, 225, 300', alt: product.title
										}}
									{% endif %}
									<div class="comparison-product-card__title">{{ product.title }}</div>
									<div class="comparison-product-card__price">{{ product.price | money }}</div>
									
									<quick-add-button
										class="no-js-hidden"
										{% if product.has_only_default_variant or product.variants.size == 1 %}
											variant-id="{{ product.first_available_variant.id }}"
										{% endif %}
										handle="{{ product.handle }}"
									>
										<button
											aria-label="{{ 'accessibility.add_to_cart' | t }}"
											class="
												button button-secondary mt-2 w-100"
										>
											<span class="flex justify-center items-center add-to-cart-span">
												{% render 'icon-product-cart-black' %}   <span> Add to cart </span>
											</span>
										</button>
									</quick-add-button>
									
								</div>
							</th>
							
							{%- comment -%} Compared products columns {%- endcomment -%}
							{% for cp in compare_products %}
								{% unless cp.id == product.id %}
									<th class="comparison-table__product-col">
										<div class="comparison-product-card">
											{% if cp.featured_image %}
												{{
													cp.featured_image
													| image_url: width: 300
													| image_tag: loading: 'lazy', widths: '150, 225, 300', alt: cp.title
												}}
											{% endif %}
											<div class="comparison-product-card__title">{{ cp.title }}</div>
											<div class="comparison-product-card__price">{{ cp.price | money }}</div>
										</div>
									</th>
								{% endunless %}
							{% endfor %}
						</tr>
						
						{% for entry in selected_features %}
							<tr>
								<th class="comparison-table__row-title">
									{{ entry.feature_name.value | default: entry.feature_name }}
								</th>
								
								{%- comment -%} Current product value {%- endcomment -%}
								{% assign current_value = entry[current_compare_key] %}
								<td>
									{% if current_value != blank %}
										{{ current_value.value | default: current_value }}
									{% else %}
										—
									{% endif %}
								</td>
								
								{%- comment -%} Compared products values {%- endcomment -%}
								{% for cp in compare_products %}
									{% unless cp.id == product.id %}
										{% assign cp_compare_key = cp.metafields.custom.compare_key.value %}
										{% if cp_compare_key == blank %}
											{% assign cp_compare_key = cp.handle | replace: '-', '_' %}
										{% endif %}
										
										{% assign cp_value = entry[cp_compare_key] | metafield_tag %}
										
										<td>
											{% if cp_value != blank %}
												{{ cp_value.value | default: cp_value }}
											{% else %}
												—
											{% endif %}
										</td>
									{% endunless %}
								{% endfor %}
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% endif %}
		
		{% if selected_features != blank and compare_products != blank and product.handle != 'enso' %}
			<div class="premium-aplus premium-aplus-module-5 aplus-container-3 comparison-table">
				{% render 'section-header' %}    
				<div id="comparison-table-container-6" data-comparison-name="comparison-table-container-6" class="a-section a-spacing-none table-container">  
				<div class="table-slider scroll-wrapper-bottom">
					<table class="a-bordered a-horizontal-stripes scroll-width">
						<tbody>
							
							<tr class="header-row">
								<td class="attribute empty first-sticky-column"></td>
								
								<th class="aplus-data-column top-header active active-item second-sticky-column">
									<div class="comparison-product-card">
										{% render 'product-card', card_product: product %}										
									</div>
								</th>
								
								{% for cp in compare_products %}
									{% unless cp.id == product.id %}
										<th class="aplus-data-column top-header">
											<div class="comparison-product-card">
												{% render 'product-card', card_product: cp %}												
											</div>
										</th>
									{% endunless %}
								{% endfor %}								
							</tr>
							
							{% for entry in selected_features %}
								<tr {%if forloop.first %}class="first-content-row"{% endif %}>
									<td class="attribute a-text-bold first-sticky-column column-cell-{{ forloop.index }}">
										<div class="comparison-metric-name" data-inline-content="" data-position="triggerRight">
											<span class="a-text-bold"> {{ entry.feature_name.value | default: entry.feature_name }} </span>
										</div>
									</td>
									
									{%- comment -%} Current product value {%- endcomment -%}
									{% assign current_value = entry[current_compare_key] | metafield_tag | strip_html %}
									<td class="aplus-data-column active active-item second-sticky-column">
										{% if current_value != blank %}
											{{ current_value.value | default: current_value }}
										{% else %}
											—
										{% endif %}
									</td>
									
									{%- comment -%} Compared products values {%- endcomment -%}
									{% for cp in compare_products %}
										{% unless cp.id == product.id %}
											{% assign cp_compare_key = cp.metafields.custom.compare_key.value %}
											{% if cp_compare_key == blank %}
												{% assign cp_compare_key = cp.handle | replace: '-', '_' %}
											{% endif %}
											
											{% assign cp_value = entry[cp_compare_key] | metafield_tag | strip_html %}
											<td class="aplus-data-column secondary-content-column">
												{% if cp_value != blank %}
													{{ cp_value.value | default: cp_value }}
												{% else %}
													—
												{% endif %}
											</td>
										{% endunless %}
									{% endfor %}									
								</tr>
							{% endfor %}							
						</tbody>
					</table>
				</div>
			</div> 
		</div>
	{% else %}
		<div class="premium-aplus premium-aplus-module-5 aplus-container-3 comparison-table enso-comparison">
			{% render 'section-header' %}    
			<div id="comparison-table-container-6" data-comparison-name="comparison-table-container-6" class="a-section a-spacing-none table-container">  
			<div class="table-slider scroll-wrapper-bottom">
				<table class="a-bordered a-horizontal-stripes scroll-width">
					<tbody>
						
						<tr class="header-row">
							<td class="attribute empty"></td>
							
							<th class="aplus-data-column top-header active active-item">
								<div class="comparison-product-card">
									{% render 'product-card', card_product: product %}
								</div>
							</th>
							
							<th class="aplus-data-column top-header">
								<div class="relative overflow-hidden group/media">
									<a href="{{ url }}" tabindex="-1" data-instant aria-label="{{ card_product.title | default: 'Product' }}">
										<div
											class="product-card-media media rounded-block [--aspect-ratio:--product-card-image-aspect] md:pb-6"
										>
											<lqip-element class="image-loader h-full">
												<img src="https://cdn.shopify.com/s/files/1/0777/8339/files/71Bhm4vc2SL._SX679.jpg?v=1775045042&width=1440"
													widths="360, 450, 540, 630, 720, 900, 1050, 1200, 1320, 1440" loading="lazy" width="" height=""
													class="product-card__image product-thumbnail-shade"/>
												</lqip-element>
											</div>
										</a>
									</div>
								</th>
								
								<th class="aplus-data-column top-header">
									<div class="relative overflow-hidden group/media">
										<a href="{{ url }}" tabindex="-1" data-instant aria-label="{{ card_product.title | default: 'Product' }}">
											<div
												class="product-card-media media rounded-block [--aspect-ratio:--product-card-image-aspect] md:pb-6"
											>
												<lqip-element class="image-loader h-full">
													<img src="https://cdn.shopify.com/s/files/1/0777/8339/files/51z90B1mVTL._AC_SY300_SX300_QL70_ML2.jpg?v=1775046681"
														widths="360, 450, 540, 630, 720, 900, 1050, 1200, 1320, 1440" loading="lazy" width="" height=""
														class="product-card__image product-thumbnail-shade"/>
													</lqip-element>
												</div>
											</a>
										</div>
									</th>
								</tr>
								
								{% for entry in selected_features %}{% endfor %}
								<tr class="first-content-row">
									<td class="attribute a-text-bold column-cell-1">
										<div class="comparison-metric-name " data-inline-content="" data-position="triggerRight">
											<span class="a-text-bold"> Category </span>
										</div>
									</td>
									
									{%- comment -%} Current product value {%- endcomment -%}
									<td class="aplus-data-column active active-item second-sticky-column">
										Electric hookah
									</td>
									<td class="aplus-data-column secondary-content-column">
										Coal hookah
									</td>
									<td class="aplus-data-column secondary-content-column">
										Home vape
									</td>
									
									
									{%- comment -%} Compared products values {%- endcomment -%}
									{% for cp in compare_products %}
										{% unless cp.id == product.id %}
											{% assign cp_compare_key = cp.metafields.custom.compare_key.value %}
											{% if cp_compare_key == blank %}
												{% assign cp_compare_key = cp.handle | replace: '-', '_' %}
											{% endif %}
											
											{% assign cp_value = entry[cp_compare_key] | metafield_tag %}
											<td class="aplus-data-column" style="min-width: 230px;">
												{% if cp_value != blank %}
													{{ cp_value.value | default: cp_value }}
												{% else %}
													—
												{% endif %}
											</td>
										{% endunless %}
									{% endfor %}									
								</tr>
								
								<tr>   
								<td class="attribute a-text-bold">
									<div class="comparison-metric-name " data-inline-content="" data-position="triggerRight">
										<span class="a-text-bold"> Heat style </span>
									</div>
								</td>
								<td class="aplus-data-column active active-item second-sticky-column">
									<span class="description">
										Clean electric
									</span>
								</td>      
								<td class="aplus-data-column secondary-content-column">
									<span class="description">
										Burning coal
									</span>
								</td>           
								<td class="aplus-data-column secondary-content-column">
									<span class="description">
										Dry heat
									</span>
								</td>      
							</tr> 
							
							<tr>   
							<td class="attribute a-text-bold">
								<div class="comparison-metric-name " data-inline-content="" data-position="triggerRight">
									<span class="a-text-bold"> What you use </span>
								</div>
							</td>
							<td class="aplus-data-column active active-item second-sticky-column">
								<span class="description">
									Molasses + dry herb
								</span>
							</td>      
							<td class="aplus-data-column secondary-content-column">
								<span class="description">
									Shisha molasses
								</span>
							</td>           
							<td class="aplus-data-column secondary-content-column">
								<span class="description">
									Dry herb
								</span>
							</td>      
							
						</tr> 
						
						<tr>   
						<td class="attribute a-text-bold">
							<div class="comparison-metric-name " data-inline-content="" data-position="triggerRight">
								<span class="a-text-bold"> Flavor quality </span>
