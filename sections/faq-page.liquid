<style>
  .faq-page { max-width: 860px; margin: 0 auto; padding: 40px 20px; }
  
  .faq-heading { font-size: 2rem; font-weight: 600; margin: 48px 0 16px; border-bottom: 1px solid #e5e5e5; padding-bottom: 10px; }
  
  .faq-subheading { font-size: 24px; font-weight: 600; margin: 28px 0 10px; color: #111; }
  
  .faq-accordions { display: flex; flex-direction: column; gap: 0px; }
  
  .faq-item { border-radius: 8px; overflow: hidden; }
  
  .faq-question {
    width: 100%;
    padding: 10px 20px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    gap: 5px;
    align-items: center;
    border: none;
    border-bottom: 1px solid #8080803d;
    background: none;
    text-align: left;
    font-size: inherit;
    font-family: inherit;
  }
  .faq-question svg {
    min-height: 30px;
    min-width: 30px;
    max-height: 30px;
    max-width: 30px;
    border-radius: 50%;
    transform: rotate(90deg);
    transition: transform .2s;
    background-color: #e0e2e3;
    padding: 8px;
  }
  .faq-question.metaobject-active svg {
    transform: rotate(270deg);
  }

  .faq-answer {
    padding: 0 20px;
    line-height: 1.7;
    color: #444;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }
  .faq-answer > .metafield-rich_text_field {
    margin: 16px 0;
  }

  .faq-answer > .metafield-rich_text_field > *:not(:last-child) {
    margin-bottom: 10px;
}

	.faq-group-addtional-info a {
		display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1em 1.5em;
    border: 0;
    border-radius: var(--button-corner-radius);
    font: inherit;
    text-decoration: none;
    cursor: pointer;
    -webkit-user-select: none;
    user-select: none;
    letter-spacing: .05em;
    text-align: center;
    background: rgb(var(--button-background) / var(--button-background-opacity, 1));
    color: rgb(var(--button-foreground));
    transition: background-color .2s, color .2s, box-shadow .2s;
    text-transform: var(--button-text-transform);
    font-family: var(--button-font-family);
    font-weight: 500;
    line-height: 1;
    position: relative;
    font-size: var(--size-text-sm);
	}

  @media (max-width: 768px) {
    .faq-heading { font-size: 28px; margin-top: 16px; }
    .faq-subheading { font-size: 20px; }
    .faq-question { padding-left: 0; padding-right: 0; font-size: 14px }
    .faq-answer { padding: 0 10px; font-size: 14px }
  }
</style>

<div class="faq-page">
  
  {% assign faq_groups = shop.metaobjects.faq_group.values | sort: 'sort_order' %}
  
  {% for group in faq_groups %}
    <div class="faq-group">
      <h2 class="faq-heading">{{ group.heading }}</h2>
      {% if group.direct_answers != blank %}
        <div class="faq-accordions">
          {% for item in group.direct_answers.value %}
            <div class="faq-item">
              <button class="faq-question metaobject-accordion">
                {{ item.question }}
                {% render 'icon-chevron' %}
              </button>
              <div class="faq-answer">{{ item.answer | metafield_tag }}</div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      
      {% if group.sections != blank %}
        {% for section in group.sections.value %}
          <div class="faq-section">
            <h3 class="faq-subheading">{{ section.subheading }}</h3>
            <div class="faq-accordions">
              {% for item in section.answers.value %}
                <div class="faq-item">
                  <button class="faq-question metaobject-accordion">
                    {{ item.question }}
                    {% render 'icon-chevron' %}
                  </button>
                  <div class="faq-answer">{{ item.answer | metafield_tag }}</div>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endif %}

			{% if group.additional_information != blank %}
				<div class="faq-group-addtional-info">
					{{ group.additional_information | metafield_tag }}
				</div>
			{% endif %}
      
    </div>
  {% endfor %}
  
</div>

