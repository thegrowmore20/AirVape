<script>
const acc = document.getElementsByClassName("metaobject-accordion");
const HEADER_OFFSET = 70; // adjust to match your sticky header height in px

for (let i = 0; i < acc.length; i++) {
  acc[i].addEventListener("click", function() {
    const clickedBtn = this;
    const panel = clickedBtn.nextElementSibling;
    const isOpening = !clickedBtn.classList.contains("metaobject-active");

    // Close all others
    for (let j = 0; j < acc.length; j++) {
      if (acc[j] !== clickedBtn) {
        acc[j].classList.remove("metaobject-active");
        acc[j].nextElementSibling.style.maxHeight = null;
      }
    }

    // Toggle current
    clickedBtn.classList.toggle("metaobject-active");
    if (panel.style.maxHeight) {
      panel.style.maxHeight = null;
    } else {
      panel.style.maxHeight = panel.scrollHeight + "px";
    }

    // If opening, scroll it into view after transition
    if (isOpening) {
      setTimeout(function() {
        const btnTop = clickedBtn.getBoundingClientRect().top + window.scrollY;
        const targetScroll = btnTop - HEADER_OFFSET;
        if (window.scrollY > targetScroll) {
          window.scrollTo({ top: targetScroll, behavior: 'smooth' });
        }
      }, 320); // slightly after the 300ms transition ends
    }
  });
}
</script>



