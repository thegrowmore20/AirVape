{%- liquid
  comment
    Determine page type from request — handles all Shopify page types
    request.page_type returns: index, product, collection, blog, article,
    page, cart, search, customers/login, customers/register, etc.
    We normalise "customers/*" → "customers" and "gift_card" stays as-is.
  endcomment

  assign page = request.page_type
  if page contains 'customers'
    assign page = 'customers'
  endif

  assign block_key       = 'block_'       | append: page
  assign scroll_key      = 'scroll_'      | append: page
  assign interaction_key = 'interaction_' | append: page

  comment
    Build per-category arrays, then deduplicate by URL (not by block object)
    so duplicate URL entries never create duplicate rules.
  endcomment

  assign arr_block       = '' | split: ''
  assign arr_scroll      = '' | split: ''
  assign arr_interaction = '' | split: ''
  assign seen_urls       = '' | split: ''

  for block in section.blocks
    assign url = block.settings.url | strip
    if url == blank
      continue
    endif

    comment
      Check if this URL already seen — skip duplicates across all load types
    endcomment
    assign already_seen = false
    for seen in seen_urls
      if seen == url
        assign already_seen = true
        break
      endif
    endfor
    if already_seen
      continue
    endif

    comment
      Verify the URL is actually present in content_for_header
    endcomment
    assign url_escaped = url | replace: '/', '\/'
    unless content_for_header contains url_escaped
      continue
    endunless

    assign seen_urls = seen_urls | push: url

    if block.settings[block_key] == true
      assign arr_block = arr_block | push: block
    elsif block.settings[scroll_key] == true
      assign arr_scroll = arr_scroll | push: block
    elsif block.settings[interaction_key] == true
      assign arr_interaction = arr_interaction | push: block
    endif
  endfor

  comment
    Build the final settings_data only when enabled and something matched
  endcomment
  assign has_rules = false
  if section.settings.enable
    if arr_block.size > 0 or arr_scroll.size > 0 or arr_interaction.size > 0
      assign has_rules = true
    endif
  endif
-%}

<!-- APP-OPTIMIZATION | enable={{ section.settings.enable }} | page={{ page }} | blocks={{ section.blocks.size }} | block={{ arr_block.size }} | scroll={{ arr_scroll.size }} | interaction={{ arr_interaction.size }} -->
{% for block in section.blocks %}<!-- block[{{ forloop.index }}] title="{{ block.settings.title }}" url="{{ block.settings.url }}" {{ block_key }}="{{ block.settings[block_key] }}" {{ scroll_key }}="{{ block.settings[scroll_key] }}" {{ interaction_key }}="{{ block.settings[interaction_key] }}" -->{% endfor %}

{%- if has_rules -%}
<!-- section/app-optimization.liquid -->
{%- comment -%}
  CRITICAL: This <script> tag has NO src, NO defer, NO async.
  It is an inline script that MUST execute synchronously, as early as possible
  in the <head>, before Shopify injects app scripts via content_for_header.
  This is intentional and is NOT render-blocking in a harmful way —
  it is a tiny interceptor (~2 KB) that runs once and returns immediately.
  The actual app scripts it defers are the ones that were render-blocking before.
{%- endcomment -%}
<script>
(function AppOptimization() {
  'use strict';

  /* ── Config passed from Liquid ─────────────────────────────────────── */
  var PAGE  = {{ page | json }};
  var DEBUG = {{ section.settings.debug_enable | json }};

  /* ── Rule sets from Liquid ─────────────────────────────────────────── */
  var BLOCK_RULES = [
    {%- for block in arr_block -%}
      {{ block.settings | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
  var SCROLL_RULES = [
    {%- for block in arr_scroll -%}
      {{ block.settings | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
  var INTERACTION_RULES = [
    {%- for block in arr_interaction -%}
      {{ block.settings | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  /* ── Passive event listener support ───────────────────────────────── */
  var supportsPassive = false;
  try {
    var _po = Object.defineProperty({}, 'passive', { get: function () { supportsPassive = true; } });
    window.addEventListener('_test', null, _po);
    window.removeEventListener('_test', null, _po);
  } catch (e) {}
  function passiveOpt(opts) { return supportsPassive ? opts : false; }

  /* ── Save native createElement BEFORE any patching ────────────────── */
  var _nativeCreate = document.createElement.bind(document);

  /* ── Internal state ────────────────────────────────────────────────── */
  // Map of url → { loadType, settings, handled }
  var ruleIndex = {};

  function registerRule(settings, loadType) {
    var url = (settings.url || '').trim();
    if (!url) return;
    if (ruleIndex[url]) return; // already registered (URL dedup safety net)
    ruleIndex[url] = { loadType: loadType, settings: settings, handled: false };
  }

  BLOCK_RULES.forEach(function (s) { registerRule(s, 'block'); });
  SCROLL_RULES.forEach(function (s) { registerRule(s, 'scroll'); });
  INTERACTION_RULES.forEach(function (s) { registerRule(s, 'interaction'); });

  debugLog('Initialized', { page: PAGE, block: BLOCK_RULES.length, scroll: SCROLL_RULES.length, interaction: INTERACTION_RULES.length });

  /* ── Rule matcher: returns the rule entry or null ─────────────────── */
  function matchRule(src) {
    if (!src) return null;
    var srcStr = String(src);
    for (var url in ruleIndex) {
      if (ruleIndex.hasOwnProperty(url) && srcStr.indexOf(url) !== -1) {
        return ruleIndex[url];
      }
    }
    return null;
  }

  /* ══════════════════════════════════════════════════════════════════════
     STRATEGY 1 — Patch document.createElement
     Catches dynamically-created <script> elements (app SDK loaders, etc.)
     Must run synchronously before any app scripts execute.
  ══════════════════════════════════════════════════════════════════════ */
  document.createElement = function (tagName) {
    var node = _nativeCreate(tagName);
    if (String(tagName).toLowerCase() !== 'script') return node;

    var _setAttr = node.setAttribute.bind(node);
    var _getAttr = node.getAttribute.bind(node);

    Object.defineProperty(node, 'src', {
      configurable: true,
      get: function () { return _getAttr('src') || ''; },
      set: function (src) {
        var rule = matchRule(src);
        if (rule && !rule.handled) {
          /* Block browser execution by setting an unrecognised type */
          _setAttr('type', 'javascript/blocked');
          rule.handled = true;
          rule.originalSrc = src;
          scheduleLoad(rule);
          debugLog('Intercepted [createElement]', { url: src, loadType: rule.loadType });
        } else {
          debugLog('Passthrough [createElement]', { url: src });
        }
        _setAttr('src', src);
      }
    });

    return node;
  };

  /* ══════════════════════════════════════════════════════════════════════
     STRATEGY 2 — MutationObserver on <html>
     Catches <script src="..."> nodes inserted directly into the DOM
     (Shopify App Embed Blocks do this via content_for_header).
  ══════════════════════════════════════════════════════════════════════ */
  var _observer = new MutationObserver(function (mutations) {
    for (var m = 0; m < mutations.length; m++) {
      var added = mutations[m].addedNodes;
      for (var n = 0; n < added.length; n++) {
        interceptNode(added[n]);
      }
    }
  });

  _observer.observe(document.documentElement, { childList: true, subtree: true });

  function interceptNode(node) {
    if (!node || node.nodeType !== 1) return;

    if (node.nodeName === 'SCRIPT') {
      blockScriptNode(node);
    }

    /* Also intercept any script descendants of an inserted fragment */
    if (typeof node.querySelectorAll === 'function') {
      var children = node.querySelectorAll('script[src]');
      for (var i = 0; i < children.length; i++) {
        blockScriptNode(children[i]);
      }
    }
  }

  function blockScriptNode(node) {
    var src = node.getAttribute('src');
    if (!src) return;

    /* Skip if already blocked by Strategy 1 */
    if (node.getAttribute('type') === 'javascript/blocked') return;

    var rule = matchRule(src);
    if (!rule) {
      debugLog('Passthrough [MutationObserver]', { url: src });
      return;
    }

    if (rule.handled) {
      debugLog('Already handled [MutationObserver]', { url: src });
      return;
    }

    node.setAttribute('type', 'javascript/blocked');
    rule.handled = true;
    rule.originalSrc = src;
    scheduleLoad(rule);
    debugLog('Intercepted [MutationObserver]', { url: src, loadType: rule.loadType });
  }

  /* Disconnect observer once the page is fully loaded — nothing new expected */
  window.addEventListener('load', function () {
    _observer.disconnect();

    /* Final sweep: warn about any matched scripts that executed anyway */
    var allScripts = document.querySelectorAll('script[src]');
    for (var i = 0; i < allScripts.length; i++) {
      var src = allScripts[i].getAttribute('src');
      var rule = matchRule(src);
      if (!rule) continue;
      if (allScripts[i].getAttribute('type') === 'javascript/blocked') continue;
      if (allScripts[i].getAttribute('data-ao-loaded')) continue;
      debugLog('WARNING — script may have executed before intercept', { url: src, loadType: rule.loadType });
    }
  }, false);

  /* ══════════════════════════════════════════════════════════════════════
     SCHEDULE LOAD — decides WHEN to actually load the deferred script
  ══════════════════════════════════════════════════════════════════════ */
  function scheduleLoad(rule) {
    var loadType = rule.loadType;

    /* ── BLOCK: never load ─────────────────────────────────────────── */
    if (loadType === 'block') {
      debugLog('Blocked permanently', { url: rule.originalSrc });
      return;
    }

    /* ── SCROLL: load on first scroll after window.load ───────────── */
    if (loadType === 'scroll') {
      afterWindowLoad(function () {
        var passive = passiveOpt({ passive: true });
        var fired = false;

        function onScroll() {
          if (fired) return;
          fired = true;
          window.removeEventListener('scroll', onScroll, passive);
          loadScript(rule.originalSrc);
        }

        /* If user has already scrolled (e.g. browser restores position) */
        if (window.scrollY > 0 || document.documentElement.scrollTop > 0) {
          loadScript(rule.originalSrc);
        } else {
          window.addEventListener('scroll', onScroll, passive);
          debugLog('Waiting for scroll', { url: rule.originalSrc });
        }
      });
      return;
    }

    /* ── INTERACTION: load on user-configured event ────────────────── */
    if (loadType === 'interaction') {
      afterWindowLoad(function () {
        var settings = rule.settings;
        var triggers = [
          { selector: settings.interaction_selectors_1, event: settings.interaction_event_1 },
          { selector: settings.interaction_selectors_2, event: settings.interaction_event_2 }
        ];

        var registered = 0;

        triggers.forEach(function (trigger) {
          var sel = (trigger.selector || '').trim();
          var evt = (trigger.event || 'click');
          if (!sel) return;

          /* Support comma-separated selectors */
          var selList = sel.split(',');
          selList.forEach(function (singleSel) {
            singleSel = singleSel.trim();
            if (!singleSel) return;

            var nodes;
            try { nodes = Array.prototype.slice.call(document.querySelectorAll(singleSel)); }
            catch (e) { nodes = []; }

            nodes.forEach(function (el) {
              var once = passiveOpt({ once: true, passive: true });

              function handler() {
                if (!once) el.removeEventListener(evt, handler);
                loadScript(rule.originalSrc);
              }

              el.addEventListener(evt, handler, once);
              registered++;
            });
          });
        });

        if (registered === 0) {
          debugLog('WARNING — no interaction elements found, falling back to scroll', { url: rule.originalSrc });
          /* Fallback: load on scroll so the script is never permanently lost */
          var passive = passiveOpt({ passive: true });
          var fired = false;
          function fallbackScroll() {
            if (fired) return;
            fired = true;
            window.removeEventListener('scroll', fallbackScroll, passive);
            loadScript(rule.originalSrc);
          }
          window.addEventListener('scroll', fallbackScroll, passive);
        } else {
          debugLog('Waiting for interaction', { url: rule.originalSrc, triggers: registered });
        }
      });
      return;
    }
  }

  /* ══════════════════════════════════════════════════════════════════════
     LOAD SCRIPT — inject a real <script> tag using the native createElement
  ══════════════════════════════════════════════════════════════════════ */
  function loadScript(src) {
    if (!src) return;

    /* Guard: already loaded */
    if (document.querySelector('script[data-ao-loaded][src="' + src + '"]')) {
      debugLog('Already loaded — skipping', { url: src });
      return;
    }

    /* Use the NATIVE createElement — not our patched version */
    var script = _nativeCreate('script');
    script.src = src;
    script.async = true;
    script.setAttribute('data-ao-loaded', 'true');

    /* Remove the blocked placeholder if it exists */
    var blocked = document.querySelector('script[type="javascript/blocked"][src="' + src + '"]');
    if (blocked && blocked.parentNode) {
      blocked.parentNode.removeChild(blocked);
    }

    (document.body || document.head || document.documentElement).appendChild(script);
    debugLog('Script loaded', { url: src });
  }

  /* ══════════════════════════════════════════════════════════════════════
     HELPERS
  ══════════════════════════════════════════════════════════════════════ */

  /* Run callback after window load (or immediately if already fired) */
  var _windowLoaded = false;
  window.addEventListener('load', function () { _windowLoaded = true; }, false);

  function afterWindowLoad(fn) {
    if (_windowLoaded || document.readyState === 'complete') {
      fn();
    } else {
      window.addEventListener('load', fn, false);
    }
  }

  /* ── Debug panel ─────────────────────────────────────────────────── */
  var _panel = null;

  function debugLog(label, data) {
    if (!DEBUG) return;
    console.log('[AppOptimization]', label, data || '');

    if (!_panel) _panel = buildPanel();
    var body = document.getElementById('ao-panel-body');
    if (!body) return;

    var entry = _nativeCreate('div');
    entry.style.cssText = 'border-bottom:1px solid #2d2d2d;padding:5px 0;font-size:11px';

    var isWarn  = String(label).indexOf('WARNING') !== -1;
    var isLoad  = String(label).indexOf('loaded') !== -1 || String(label).indexOf('Loaded') !== -1;
    var isBlock = String(label).indexOf('Block') !== -1 || String(label).indexOf('permanently') !== -1;
    var colour  = isWarn ? '#f48771' : isLoad ? '#4ec94e' : isBlock ? '#f48771' : '#9cdcfe';

    var html = '<span style="color:' + colour + ';font-weight:700">' + label + '</span>';
    if (data && typeof data === 'object') {
      Object.keys(data).forEach(function (k) {
        var v = data[k];
        if (v === undefined || v === null) return;
        if (typeof v === 'object') v = JSON.stringify(v);
        html += '<br><span style="color:#9cdcfe">' + k + '</span>: <span style="color:#ce9178">' + v + '</span>';
      });
    }
    entry.innerHTML = html;
    body.appendChild(entry);
  }

  function buildPanel() {
    var style = _nativeCreate('style');
    style.textContent = '#ao-panel{position:fixed;bottom:16px;right:16px;z-index:2147483647;width:420px;max-height:420px;overflow-y:auto;background:#1e1e1e;color:#d4d4d4;font-family:"Courier New",monospace;font-size:11px;border-radius:8px;box-shadow:0 4px 24px rgba(0,0,0,.6)}#ao-panel-head{display:flex;justify-content:space-between;align-items:center;background:#007acc;color:#fff;font-family:-apple-system,sans-serif;font-size:12px;font-weight:600;padding:7px 12px;border-radius:8px 8px 0 0;position:sticky;top:0}#ao-panel-body{padding:8px 12px}';
    (document.head || document.documentElement).appendChild(style);

    var p = _nativeCreate('div');
    p.id = 'ao-panel';
    p.innerHTML = '<div id="ao-panel-head"><span>&#128270; App Optimization &mdash; ' + PAGE + '</span><button onclick="document.getElementById(\'ao-panel\').style.display=\'none\'" style="background:0;border:0;color:#fff;cursor:pointer;font-size:15px">&#x2715;</button></div><div id="ao-panel-body"></div>';

    if (document.body) {
      document.body.appendChild(p);
    } else {
      document.addEventListener('DOMContentLoaded', function () { document.body.appendChild(p); });
    }
    return p;
  }

})();
</script>
{%- endif -%}

{%- if request.design_mode -%}
{%- comment -%}Theme Editor UI — loaded only inside the Shopify admin customizer{%- endcomment -%}
{%- assign urls = content_for_header | split: 'var urls =' | last | split: 'for (var i = 0' | first | remove: ';' | split: ',' -%}

<template id="sd-app-list-template">
  <style>
    :host{display:block;contain:content;padding:3.2rem 1rem;background:#f6f6f7;width:100%;box-shadow:0 0 0 1px rgb(63 63 68/5%),0 1px 3px 0 rgb(63 63 68/15%)}
    .w-full{width:100%}
    .grid-container{max-width:1100px;margin:0 auto;padding:16px 2px}
    *{font-family:-apple-system,BlinkMacSystemFont,San Francisco,Segoe UI,Roboto,Helvetica Neue,sans-serif;font-size:14px;color:#202223;text-align:left}
    p{padding:0;margin:0} a{text-decoration:none} table{border-collapse:collapse} td,th{padding:16px}
    th p{text-transform:uppercase;font-size:12px;font-weight:600}
    tr{border-bottom:1px solid #e1e3e5} tr:hover,tr:hover td:first-child{background:#fafbfb} a:hover{text-decoration:underline}
    td:first-child,th:first-child{position:sticky;left:0;background:#fff} th,th:first-child{background:#fafbfb}
    [data-badge]{background-color:#e4e5e7;display:inline-block;border-radius:2rem;font-size:13px;line-height:16px;padding:3px 8px}
    [data-badge="Interaction"],[data-badge="Scroll"]{background-color:#aee9d1}
    [data-badge="Block"]{background-color:#fed3d1}
    .card{background:#fff;box-shadow:rgb(23 24 24/5%) 0 0 5px 0,rgb(0 0 0/15%) 0 1px 2px 0;border-radius:8px;overflow:auto;-webkit-overflow-scrolling:touch}
    button{background:transparent;border:0;cursor:pointer} button svg{display:block;fill:#5C5F62} button:hover svg{fill:#008060}
    h2{font-size:16px;font-weight:600;line-height:24px}
    .text-right{text-align:right} .text-center{text-align:center} .pr-8{padding-right:8px}
    .mb-4{margin-bottom:4px} .mb-32{margin-bottom:32px} .flex{display:flex} .whitespace-no-wrap{white-space:nowrap}
    .btn-outline{padding:9px 16px;border:1px solid rgb(140,145,150);border-radius:4px;display:inline-block;margin-top:16px;margin-left:8px;font-size:14px;line-height:16px}
    .btn-primary{background:#008060;color:#fff;border-color:#008060}
    .header-grid{display:grid;grid-template-columns:1.7fr 1fr}
  </style>
  <div class="grid-container">
    <div class="header-grid mb-32">
      <div>
        <h2 class="mb-4">App Optimization by Sections.design</h2>
        <p>Improve performance by optimizing how, when, and where your apps will load.</p>
      </div>
      <div class="text-right">
        <a class="btn-outline text-center" target="_blank" href="https://sections.design/blogs/shopify/app-optimization">Read blog post</a>
        <a class="btn-outline btn-primary text-center" target="_blank" href="https://youtu.be/UFdTKDPCc_Q">View setup video</a>
      </div>
    </div>
    <div class="card w-full">
      <table class="w-full">
        <thead>
          <tr>
            <th><p>Application</p></th>
            <th><p>Script URL</p></th>
            <th><p class="text-right pr-8">{{ page }} page load</p></th>
          </tr>
        </thead>
        <tbody>
        {%- for url in urls -%}
          {%- liquid
            assign name = 'App name'
            assign load = 'Default'
            assign url_clean = url | remove: '"' | remove: '[' | remove: ']' | replace: '\/', '/' | replace: '\u0026', '&' | remove: 'https://' | remove: '//' | strip
            assign url_display = url_clean | split: '?' | first

            for block in section.blocks
              if block.settings.url != blank and url_clean contains block.settings.url
                assign name = block.settings.title
                if block.settings[block_key] == true
                  assign load = 'Block'
                elsif block.settings[scroll_key] == true
                  assign load = 'Scroll'
                elsif block.settings[interaction_key] == true
                  assign load = 'Interaction'
                endif
              endif
            endfor
          -%}
          <tr>
            <td><p>{{ name }}</p></td>
            <td>
              <p class="flex whitespace-no-wrap">
                <a href="https://{{ url_clean }}" target="_blank" rel="noreferrer">{{ url_display }}</a>
                <button type="button" data-clipboard="{{ url_display }}">
                  <svg aria-hidden="true" width="14" height="14" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M7.5 2A1.5 1.5 0 006 3.5V13a1 1 0 001 1h9.5a1.5 1.5 0 001.5-1.5v-9A1.5 1.5 0 0016.5 2h-9zm-4 4H4v10h10v.5a1.5 1.5 0 01-1.5 1.5h-9A1.5 1.5 0 012 16.5v-9A1.5 1.5 0 013.5 6z"/></svg>
                </button>
              </p>
            </td>
            <td class="text-right"><p data-badge="{{ load }}">{{ load }}</p></td>
          </tr>
        {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</template>

<sd-app-list></sd-app-list>

<script>
(function ThemeEditor() {
  'use strict';
  document.addEventListener('shopify:section:select', select);
  document.addEventListener('shopify:section:load',   load);
  document.addEventListener('shopify:section:deselect', deselect);

  function select(evt) {
    if (evt.detail.sectionId !== 'app-optimization') return;
    var node = document.querySelector('sd-app-list');
    if (node) node.removeAttribute('style');
    if (customElements.get('sd-app-list')) return;
    defineElement();
    initCopyEvents(node.shadowRoot);
  }

  function load(evt) {
    if (evt.detail.sectionId !== 'app-optimization') return;
    var sr = document.querySelector('sd-app-list').shadowRoot;
    Array.prototype.slice.call(sr.children).forEach(function (n) { n.parentNode.removeChild(n); });
    sr.appendChild(templateContent());
    initCopyEvents(sr);
  }

  function deselect(evt) {
    if (evt.detail.sectionId !== 'app-optimization') return;
    var node = document.querySelector('sd-app-list');
    if (node) node.style.display = 'none';
  }

  function defineElement() {
    customElements.define('sd-app-list', class extends HTMLElement {
      constructor() {
        super();
        this.attachShadow({ mode: 'open' }).appendChild(templateContent());
      }
    });
  }

  function templateContent() {
    return document.getElementById('sd-app-list-template').content.cloneNode(true);
  }

  function initCopyEvents(sr) {
    Array.prototype.slice.call(sr.querySelectorAll('[data-clipboard]'))
      .forEach(function (n) { n.addEventListener('click', copyText); });
  }

  function copyText() {
    navigator.clipboard.writeText(this.getAttribute('data-clipboard'));
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "App Optimization",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable App Optimization?",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "debug_enable",
      "label": "Enable debug panel?",
      "default": false,
      "info": "Shows a floating debug panel on the storefront with real-time script loading info"
    }
  ],
  "blocks": [
    {
      "type": "app",
      "name": "Application",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "App title"
        },
        {
          "type": "text",
          "id": "url",
          "label": "App ScriptTag URL (partial)",
          "placeholder": "e.g. static.klaviyo.com/onsite/js/klaviyo.js",
          "info": "Enter a partial URL that uniquely identifies this app's script. Example: klaviyo.com or loox.io"
        },

        { "type": "header", "content": "Block script from loading" },
        { "type": "paragraph", "content": "Script will NOT load at all on the selected pages." },
