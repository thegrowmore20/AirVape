	<script>
(function() {
	if (window.innerWidth > 767) return;
    const sourceSelector = '.wishtlist-wrapper';
    const targetSelector = '.new-header-wishharea-mob';
    const iconClass = '.xb-wishlist-header__icon';
    const quantityClass = '.xb-product-quantity';

    const observer = new MutationObserver((mutations, obs) => {
        const source = document.querySelector(sourceSelector);
        const target = document.querySelector(targetSelector);

        // We check for the wrapper and the icon first
        if (source && target && source.querySelector(iconClass)) {
            
            // Remove the hidden class so it's visible in the new spot
            source.classList.remove('hidden--mobile');

            // MOVE the elements instead of copying HTML
            // This keeps the "live" link for the quantity to update
            while (source.firstChild) {
                target.appendChild(source.firstChild);
            }

            // Once moved, we check if the quantity is there. 
            // If the app is slow, the observer will keep running until it sees it.
            if (target.querySelector(quantityClass)) {
                console.log('Wishlist and Quantity moved successfully.');
                obs.disconnect(); // Task complete
            }
        }
    });

    observer.observe(document.body, {
        childList: true,
        subtree: true
    });
})();
	</script>

