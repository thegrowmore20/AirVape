          <div class="ai-slider-slide-{{ ai_gen_id }}" data-slide-index="{{ slide_index | minus: 1 }}">
            {% if slide_index <= desktop_visible %}
             <lqip-element class="image-loader">
              <img
                src="{{ block.settings.image_2 | image_url: width: 800 }}"
                alt="{{ block.settings.image_2.alt | escape }}"
                width="{{ block.settings.image_2.width }}"
                height="{{ block.settings.image_2.height }}"
                loading="{% if slide_index <= mobile_visible %}eager{% else %}lazy{% endif %}"
                class="ai-slider-slide-image-{{ ai_gen_id }}"
              >
                </lqip-element>
            {% else %}
             <lqip-element class="image-loader">
              <img
                data-src="{{ block.settings.image_2 | image_url: width: 800 }}"
                alt="{{ block.settings.image_2.alt | escape }}"
                width="{{ block.settings.image_2.width }}"
                height="{{ block.settings.image_2.height }}"
                loading="lazy"
                class="ai-slider-slide-image-{{ ai_gen_id }} ai-slider-lazy-{{ ai_gen_id }}"
              >
                </lqip-element>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.image_3 %}
          {% assign slide_index = slide_index | plus: 1 %}
          <div class="ai-slider-slide-{{ ai_gen_id }}" data-slide-index="{{ slide_index | minus: 1 }}">
            {% if slide_index <= desktop_visible %}
             <lqip-element class="image-loader">
              <img
