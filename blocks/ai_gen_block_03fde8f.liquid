{% doc %}
  @prompt
    Create a image slider for a fully responsive, Core Web Vitals-friendly.
    
    Main functionality:
    - The slider must support image slides only.
    - Allow adding multiple slides through section blocks.
    - The slider must be reusable and flexible.
    
    Responsive layout:
    - Desktop: show 4 slides
    - Tablet/small devices: show 3 slides
    - Mobile: show 2 slides
    - Also provide settings to customize the number of visible slides separately for desktop, tablet, and mobile.
    
    Navigation and interaction:
    - Enable drag/swipe functionality for mouse, touchpad, and touch devices.
    - Include arrows and dots navigation.
    - Add separate toggle settings to enable/disable arrows and dots.
    - Add color picker settings for arrows and dots.
    - Automatically hide arrows and dots when the total number of slides is less than or equal to the number of visible slides for the current device/view.
    - Add optional settings for:
      - autoplay on/off
      - autoplay speed
      - infinite loop on/off
      - spacing/gap between slides
    
    Metafield support:
    - Add an option to populate slider data from Shopify metafields.
    - There should be settings for:
      - namespace
      - key
    - This should allow me to reuse the section easily by changing the metafield namespace and key.
    - The section should support dynamic content output from metafields so I can replace the source without rebuilding the section.
    - Include logic so the slider can work with either:
      1. manually added section blocks
      2. metafield-based dynamic data
    - Ideally provide a setting to choose the source type:
      - manual slides
      - metafield source
    
    Performance and Core Web Vitals:
    - The slider must be fully optimized and should not negatively affect Core Web Vitals.
    - Use proper lazy loading for images.
    - Do not preload all slides at once.
    - Prioritize above-the-fold content only and lazy load the rest intelligently.
    - Load only visible or near-visible slide assets initially.
    - Prevent CLS by defining image dimensions or aspect ratios.
    - Use responsive image output and optimized asset loading.
    - Avoid render-blocking scripts and unnecessary libraries.
    - Keep JavaScript minimal, efficient, and performance-friendly.
    - Ensure the slider is smooth and responsive without harming LCP, CLS, or INP.
    
    Expected result:
    - Smooth, modern, and production-ready Shopify section
    - Fully responsive across desktop, tablet, and mobile
    - No layout breaking or overflow issues
    - Easy to customize from Shopify theme editor
    - Clean, maintainable, lightweight code
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign namespace = block.settings.metafield_namespace
  assign key = block.settings.metafield_key
  assign use_metafield = block.settings.use_metafield_source
  assign metafield_images = null

  if use_metafield and namespace != blank and key != blank
    assign metafield_value = product.metafields[namespace][key]
    if metafield_value
      assign metafield_images = metafield_value.value
    endif
  endif

  assign manual_images = ''
  assign manual_images = manual_images | append: block.settings.image_1
  assign manual_images = manual_images | append: ',' | append: block.settings.image_2
  assign manual_images = manual_images | append: ',' | append: block.settings.image_3
  assign manual_images = manual_images | append: ',' | append: block.settings.image_4
  assign manual_images = manual_images | append: ',' | append: block.settings.image_5
  assign manual_images = manual_images | append: ',' | append: block.settings.image_6
  assign manual_images = manual_images | append: ',' | append: block.settings.image_7
  assign manual_images = manual_images | append: ',' | append: block.settings.image_8

  assign total_slides = 0
  if use_metafield and metafield_images
    assign total_slides = metafield_images.size
  else
    if block.settings.image_1 != blank
      assign total_slides = total_slides | plus: 1
    endif
    if block.settings.image_2 != blank
      assign total_slides = total_slides | plus: 1
    endif
    if block.settings.image_3 != blank
      assign total_slides = total_slides | plus: 1
    endif
    if block.settings.image_4 != blank
      assign total_slides = total_slides | plus: 1
    endif
    if block.settings.image_5 != blank
      assign total_slides = total_slides | plus: 1
    endif
    if block.settings.image_6 != blank
      assign total_slides = total_slides | plus: 1
    endif
    if block.settings.image_7 != blank
      assign total_slides = total_slides | plus: 1
    endif
    if block.settings.image_8 != blank
      assign total_slides = total_slides | plus: 1
    endif
  endif

  assign desktop_visible = block.settings.slides_desktop
  assign tablet_visible = block.settings.slides_tablet
  assign mobile_visible = block.settings.slides_mobile
%}

{% style %}
  .ai-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    position: relative;
    padding: 0;
  }

  .ai-slider-container-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ai-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.slide_gap }}px;
    transition: transform 0.3s ease;
    will-change: transform;
    touch-action: pan-y;
    user-select: none;
  }

  .ai-slider-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ mobile_visible | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ mobile_visible }});
    min-width: 0;
    position: relative;
  }

  .ai-slider-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-slider-slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slider-slide-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-slider-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_color }};
    color: {{ block.settings.arrow_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
    opacity: 0.9;
  }

  .ai-slider-arrow-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-slider-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-slider-arrow-{{ ai_gen_id }}.ai-slider-hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-slider-arrow-prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-slider-arrow-next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-slider-arrow-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-slider-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .ai-slider-dots-{{ ai_gen_id }}.ai-slider-hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-slider-dot-{{ ai_gen_id }}:hover {
    opacity: 0.6;
  }

  .ai-slider-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  @media screen and (min-width: 750px) {
    .ai-slider-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ tablet_visible | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ tablet_visible }});
    }
  }

  @media screen and (min-width: 990px) {
    .ai-slider-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ desktop_visible | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ desktop_visible }});
    }
  }
{% endstyle %}

<image-slider-{{ ai_gen_id }}
  class="ai-slider-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.enable_autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-infinite="{{ block.settings.enable_infinite }}"
  data-desktop-slides="{{ desktop_visible }}"
  data-tablet-slides="{{ tablet_visible }}"
  data-mobile-slides="{{ mobile_visible }}"
  data-total-slides="{{ total_slides }}"
  data-show-arrows="{{ block.settings.show_arrows }}"
  data-show-dots="{{ block.settings.show_dots }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-slider-container-{{ ai_gen_id }}">
    {% if block.settings.show_arrows %}
      <button
        class="ai-slider-arrow-{{ ai_gen_id }} ai-slider-arrow-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
        type="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-slider-arrow-{{ ai_gen_id }} ai-slider-arrow-next-{{ ai_gen_id }}"
        aria-label="Next slide"
        type="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    <div class="ai-slider-track-{{ ai_gen_id }}">
      {% if use_metafield and metafield_images %}
        {% for image in metafield_images %}
          <div class="ai-slider-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
            {% if forloop.index <= desktop_visible %}
             <lqip-element class="image-loader">
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="{% if forloop.index <= mobile_visible %}eager{% else %}lazy{% endif %}"
                class="ai-slider-slide-image-{{ ai_gen_id }}"
              >
                </lqip-element>
            {% else %}
             <lqip-element class="image-loader">
              <img
                data-src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="lazy"
                class="ai-slider-slide-image-{{ ai_gen_id }} ai-slider-lazy-{{ ai_gen_id }}"
              >
              </lqip-element>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        {% assign slide_index = 0 %}
        {% if block.settings.image_1 %}
