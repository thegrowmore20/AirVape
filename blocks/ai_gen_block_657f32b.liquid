<script>
  (function() {
    class ImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isDragging = false;
        this.startPos = 0;
        this.currentTranslate = 0;
        this.prevTranslate = 0;
        this.autoplayInterval = null;
        this.dragJustHappened = false;

        this.lightboxIndex = 0;
        this.popupItems = [];

        this.lightboxIsDragging = false;
        this.lightboxStartPos = 0;
        this.lightboxCurrentTranslate = 0;
        this.lightboxDragJustHappened = false;

        this.handleResize = this.handleResize.bind(this);
        this.handleKeydown = this.handleKeydown.bind(this);
      }

      connectedCallback() {
        this.track = this.querySelector('[data-slider-track]');
        this.slides = Array.from(this.querySelectorAll('.ai-slider-slide-{{ ai_gen_id }}'));
        this.popupSlides = Array.from(this.querySelectorAll('.ai-slider-slide-{{ ai_gen_id }}[data-popup-slide]'));
        this.controls = this.querySelector('[data-slider-controls]');
        this.prevBtn = this.querySelector('[data-slider-prev]');
        this.nextBtn = this.querySelector('[data-slider-next]');
        this.dotsContainer = this.querySelector('[data-slider-dots]');

        this.lightbox = this.querySelector('[data-lightbox]');
        this.lightboxStage = this.querySelector('.ai-slider-lightbox-stage-{{ ai_gen_id }}');
        this.lightboxImage = this.querySelector('[data-lightbox-image]');
        this.lightboxCaption = this.querySelector('[data-lightbox-caption]');
        this.lightboxDots = this.querySelector('[data-lightbox-dots]');
        this.lightboxPrevBtn = this.querySelector('[data-lightbox-prev]');
        this.lightboxNextBtn = this.querySelector('[data-lightbox-next]');

        this.settings = {
          slidesDesktop: {{ block.settings.slides_desktop }},
          slidesTablet: {{ block.settings.slides_tablet }},
          slidesMobile: {{ block.settings.slides_mobile }},
          gap: {{ block.settings.slide_gap }},
          autoplay: {{ block.settings.autoplay }},
          autoplaySpeed: {{ block.settings.autoplay_speed }},
          infinite: {{ block.settings.infinite_loop }},
          showArrows: {{ block.settings.show_arrows }},
          showDots: {{ block.settings.show_dots }},
          enablePopup: true
        };

        if (this.slides.length === 0) return;

        this.init();
      }

      init() {
        this.updateSlidesPerView();
        this.updateSlideWidths();
        this.createDots();
        this.updateControls();
        this.preparePopupItems();
        this.createLightboxDots();
        this.attachEvents();
        this.goToSlide(this.currentIndex);

        if (this.settings.autoplay) {
          this.startAutoplay();
        }

        window.addEventListener('resize', this.handleResize);
        document.addEventListener('keydown', this.handleKeydown);
      }

      handleResize() {
        this.updateSlidesPerView();
        this.updateSlideWidths();
        this.createDots();
        this.goToSlide(Math.min(this.currentIndex, this.maxIndex));
      }

      updateSlidesPerView() {
        const width = window.innerWidth;

        if (width < 750) {
          this.slidesPerView = this.settings.slidesMobile;
        } else if (width < 990) {
          this.slidesPerView = this.settings.slidesTablet;
        } else {
          this.slidesPerView = this.settings.slidesDesktop;
        }

        this.maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
      }

      updateSlideWidths() {
        const wrapper = this.track?.parentElement;
        if (!wrapper) return;

        const containerWidth = wrapper.offsetWidth;
        const slideWidth = (containerWidth - (this.settings.gap * (this.slidesPerView - 1))) / this.slidesPerView;

        this.slides.forEach((slide) => {
          slide.style.width = slideWidth + 'px';
        });
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.dotsContainer.innerHTML = '';
        const totalDots = Math.max(1, this.slides.length - this.slidesPerView + 1);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'ai-slider-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);

          if (i === this.currentIndex) {
            dot.classList.add('active');
          }

          dot.addEventListener('click', () => {
            this.goToSlide(i);
            this.resetAutoplay();
          });

          this.dotsContainer.appendChild(dot);
        }
      }

      /* MODIFIED updateControls() for auto-scrolling dots */
      updateControls() {
        const shouldShowControls = this.slides.length > this.slidesPerView;

        if (this.controls) {
          this.controls.classList.toggle('hidden', !shouldShowControls);
        }

        if (this.prevBtn && this.nextBtn && !this.settings.infinite) {
          this.prevBtn.disabled = this.currentIndex === 0;
          this.nextBtn.disabled = this.currentIndex >= this.maxIndex;
        }

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.ai-slider-dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            if (index === this.currentIndex) {
              dot.classList.add('active');

              // Scroll the dots container horizontally to center the active dot
              if (this.dotsContainer.scrollWidth > this.dotsContainer.clientWidth) {
                const dotLeft = dot.offsetLeft;
                const dotWidth = dot.offsetWidth;
                const containerWidth = this.dotsContainer.offsetWidth;
                
                this.dotsContainer.scrollTo({
                  left: dotLeft - (containerWidth / 2) + (dotWidth / 2),
                  behavior: 'smooth'
                });
              }

            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      preparePopupItems() {
        this.popupItems = this.popupSlides.map((slide) => {
          const img = slide.querySelector('img');
          const caption = slide.querySelector('.ai-slider-caption-{{ ai_gen_id }}');

          return {
            src: img ? (img.currentSrc || img.getAttribute('src') || '') : '',
            alt: img ? (img.getAttribute('alt') || '') : '',
            caption: caption ? caption.innerHTML : ''
          };
        }).filter(item => item.src);
      }

      createLightboxDots() {
        if (!this.lightboxDots) return;

        this.lightboxDots.innerHTML = '';

        this.popupItems.forEach((item, index) => {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'ai-slider-lightbox-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to popup image ${index + 1}`);

          if (index === this.lightboxIndex) {
            dot.classList.add('active');
          }

          dot.addEventListener('click', () => {
            this.lightboxIndex = index;
            this.renderLightbox();
          });

          this.lightboxDots.appendChild(dot);
        });
      }

      attachEvents() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => {
            this.prev();
            this.resetAutoplay();
          });
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => {
            this.next();
            this.resetAutoplay();
          });
        }

        this.track.addEventListener('mousedown', this.touchStart.bind(this));
        this.track.addEventListener('touchstart', this.touchStart.bind(this), { passive: true });
        this.track.addEventListener('mouseup', this.touchEnd.bind(this));
        this.track.addEventListener('touchend', this.touchEnd.bind(this));
        this.track.addEventListener('mouseleave', this.touchEnd.bind(this));
        this.track.addEventListener('mousemove', this.touchMove.bind(this));
        this.track.addEventListener('touchmove', this.touchMove.bind(this), { passive: true });
        this.track.addEventListener('dragstart', (e) => e.preventDefault());

        if (this.settings.enablePopup) {
          this.popupSlides.forEach((slide, index) => {
            slide.addEventListener('click', (event) => {
              this.handleSlideClick(event, index);
            });
          });
        }

        if (this.lightbox) {
          this.lightbox.addEventListener('click', (event) => {
            if (this.lightboxDragJustHappened) {
              event.preventDefault();
              event.stopPropagation();
              return;
            }

            if (event.target === this.lightbox || event.target.closest('[data-lightbox-close]')) {
              this.closeLightbox();
            }
          });
        }

        if (this.lightboxPrevBtn) {
          this.lightboxPrevBtn.addEventListener('click', () => {
            this.lightboxPrev();
          });
        }

        if (this.lightboxNextBtn) {
          this.lightboxNextBtn.addEventListener('click', () => {
            this.lightboxNext();
          });
        }

        if (this.lightboxStage) {
          this.lightboxStage.addEventListener('mousedown', this.lightboxTouchStart.bind(this));
          this.lightboxStage.addEventListener('touchstart', this.lightboxTouchStart.bind(this), { passive: true });

          this.lightboxStage.addEventListener('mousemove', this.lightboxTouchMove.bind(this));
          this.lightboxStage.addEventListener('touchmove', this.lightboxTouchMove.bind(this), { passive: true });

          this.lightboxStage.addEventListener('mouseup', this.lightboxTouchEnd.bind(this));
          this.lightboxStage.addEventListener('mouseleave', this.lightboxTouchEnd.bind(this));
          this.lightboxStage.addEventListener('touchend', this.lightboxTouchEnd.bind(this));
          this.lightboxStage.addEventListener('touchcancel', this.lightboxTouchEnd.bind(this));

          this.lightboxStage.addEventListener('dragstart', (e) => e.preventDefault());
        }
      }

      handleSlideClick(event, index) {
        if (this.dragJustHappened) {
          event.preventDefault();
          event.stopPropagation();
          return;
        }

        if (event.target.closest('a')) {
          event.preventDefault();
        }

        this.openLightbox(index);
      }

      touchStart(event) {
        this.isDragging = true;
        this.dragJustHappened = false;
        this.startPos = this.getPositionX(event);
        this.track.classList.add('dragging');
      }

      touchMove(event) {
        if (!this.isDragging) return;
        const currentPosition = this.getPositionX(event);
        this.currentTranslate = this.prevTranslate + currentPosition - this.startPos;
      }

      touchEnd() {
        if (!this.isDragging) return;

        this.isDragging = false;
        this.track.classList.remove('dragging');

        const movedBy = this.currentTranslate - this.prevTranslate;
        const absMoved = Math.abs(movedBy);

        if (absMoved > 8) {
          this.dragJustHappened = true;
          setTimeout(() => {
            this.dragJustHappened = false;
          }, 80);
        }

        if (movedBy < -50 && (this.currentIndex < this.maxIndex || this.settings.infinite)) {
          this.next();
        } else if (movedBy > 50 && (this.currentIndex > 0 || this.settings.infinite)) {
          this.prev();
        } else {
          this.goToSlide(this.currentIndex);
        }

        this.resetAutoplay();
      }

      getPositionX(event) {
        if (event.type.includes('mouse')) {
          return event.pageX;
        }

        const touch = event.touches[0] || event.changedTouches[0];
        return touch ? touch.clientX : 0;
      }

      setSliderPosition() {
        this.track.style.transform = `translateX(${this.currentTranslate}px)`;
      }

      goToSlide(index) {
        this.currentIndex = Math.max(0, Math.min(index, this.maxIndex));
        const slideWidth = this.slides[0]?.offsetWidth || 0;
        this.currentTranslate = -this.currentIndex * (slideWidth + this.settings.gap);
        this.prevTranslate = this.currentTranslate;
        this.setSliderPosition();
        this.updateControls();
      }

      next() {
        if (this.settings.infinite && this.currentIndex >= this.maxIndex) {
          this.goToSlide(0);
        } else if (this.currentIndex < this.maxIndex) {
          this.goToSlide(this.currentIndex + 1);
        }
      }

      prev() {
        if (this.settings.infinite && this.currentIndex === 0) {
          this.goToSlide(this.maxIndex);
        } else if (this.currentIndex > 0) {
          this.goToSlide(this.currentIndex - 1);
        }
      }

      openLightbox(index) {
        if (!this.lightbox || !this.popupItems.length) return;

        this.lightboxIndex = Math.max(0, Math.min(index, this.popupItems.length - 1));
        this.renderLightbox();
        this.lightbox.classList.add('active');
        this.lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        this.resetAutoplay();
      }

      closeLightbox() {
        if (!this.lightbox) return;

        this.lightbox.classList.remove('active');
        this.lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';

        if (this.lightboxStage) {
          this.lightboxStage.classList.remove('dragging');
        }

        this.lightboxCurrentTranslate = 0;
        this.lightboxIsDragging = false;
      }

      renderLightbox() {
        const item = this.popupItems[this.lightboxIndex];
        if (!item || !this.lightboxImage) return;

        this.lightboxImage.src = item.src;
        this.lightboxImage.alt = item.alt || '';

        if (this.lightboxCaption) {
          if (item.caption) {
            this.lightboxCaption.innerHTML = item.caption;
            this.lightboxCaption.style.display = 'block';
          } else {
            this.lightboxCaption.innerHTML = '';
            this.lightboxCaption.style.display = 'none';
          }
        }

        if (this.lightboxDots) {
          const dots = this.lightboxDots.querySelectorAll('.ai-slider-lightbox-dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === this.lightboxIndex);
          });
        }

        if (this.lightboxPrevBtn && this.lightboxNextBtn && !this.settings.infinite) {
          this.lightboxPrevBtn.disabled = this.lightboxIndex === 0;
          this.lightboxNextBtn.disabled = this.lightboxIndex === this.popupItems.length - 1;
        }

        this.lightboxCurrentTranslate = 0;
      }

      lightboxNext() {
        if (!this.popupItems.length) return;

        if (this.settings.infinite) {
          this.lightboxIndex = (this.lightboxIndex + 1) % this.popupItems.length;
        } else {
          this.lightboxIndex = Math.min(this.lightboxIndex + 1, this.popupItems.length - 1);
        }

        this.renderLightbox();
      }

      lightboxPrev() {
        if (!this.popupItems.length) return;

        if (this.settings.infinite) {
          this.lightboxIndex = (this.lightboxIndex - 1 + this.popupItems.length) % this.popupItems.length;
        } else {
          this.lightboxIndex = Math.max(this.lightboxIndex - 1, 0);
        }

        this.renderLightbox();
      }

      lightboxTouchStart(event) {
        const isOpen = this.lightbox && this.lightbox.classList.contains('active');
        if (!isOpen) return;

        this.lightboxIsDragging = true;
        this.lightboxDragJustHappened = false;
        this.lightboxStartPos = this.getPositionX(event);
        this.lightboxCurrentTranslate = 0;

        if (this.lightboxStage) {
          this.lightboxStage.classList.add('dragging');
        }
      }

      lightboxTouchMove(event) {
        if (!this.lightboxIsDragging) return;

        const currentPosition = this.getPositionX(event);
        this.lightboxCurrentTranslate = currentPosition - this.lightboxStartPos;
      }

      lightboxTouchEnd() {
        if (!this.lightboxIsDragging) return;

        this.lightboxIsDragging = false;

        const movedBy = this.lightboxCurrentTranslate;
        const absMoved = Math.abs(movedBy);

        if (this.lightboxStage) {
          this.lightboxStage.classList.remove('dragging');
        }

        if (absMoved > 8) {
          this.lightboxDragJustHappened = true;
          setTimeout(() => {
            this.lightboxDragJustHappened = false;
          }, 120);
        }

        if (movedBy < -50) {
          this.lightboxNext();
        } else if (movedBy > 50) {
          this.lightboxPrev();
        }

        this.lightboxCurrentTranslate = 0;
      }

      handleKeydown(event) {
        const isOpen = this.lightbox && this.lightbox.classList.contains('active');
        if (!isOpen) return;

        if (event.key === 'Escape') {
          this.closeLightbox();
        }

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          this.lightboxNext();
        }

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          this.lightboxPrev();
        }
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          const popupOpen = this.lightbox && this.lightbox.classList.contains('active');
          if (!popupOpen) {
            this.next();
          }
        }, this.settings.autoplaySpeed);
      }

      resetAutoplay() {
        if (this.settings.autoplay) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }

        window.removeEventListener('resize', this.handleResize);
        document.removeEventListener('keydown', this.handleKeydown);
      }
    }

    if (!customElements.get('image-slider-{{ ai_gen_id }}')) {
      customElements.define('image-slider-{{ ai_gen_id }}', ImageSlider{{ ai_gen_id }});
    }
  })();
</script>

