            {% for image in metafield_data.value %}
              {% liquid
                assign lazyload = 'eager'
                if forloop.index > 1
                  assign lazyload = 'lazy'
                endif
              %}
              <div class="ai-slider-slide-{{ ai_gen_id }} ai-slider-slide-custom" data-popup-slide>
                <div class="ai-slider-image-wrapper-{{ ai_gen_id }}">
