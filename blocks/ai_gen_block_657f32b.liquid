{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slider-container-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    position: relative;
  }

  .ai-slider-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ai-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.slide_gap }}px;
    align-items: stretch;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
    cursor: grab;
    user-select: none;
  }

  .ai-slider-track-{{ ai_gen_id }}.dragging {
    cursor: grabbing;
    transition: none;
  }

  .ai-slider-slide-{{ ai_gen_id }} {
    flex-shrink: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    height: auto;
  }

  .ai-slider-slide-{{ ai_gen_id }}[data-popup-slide] {
    cursor: pointer;
  }

  .ai-slider-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.slide_border_radius }}px;
    {% if block.settings.aspect_ratio == 'auto' %}
      flex-grow: 1;
    {% endif %}
  }

  .ai-slider-image-wrapper-{{ ai_gen_id }} a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-slider-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
    border-radius: {{ block.settings.slide_border_radius }}px;
  }

  {% if block.settings.aspect_ratio == 'square' %}
    .ai-slider-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 1 / 1;
    }
  {% elsif block.settings.aspect_ratio == 'landscape' %}
    .ai-slider-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 4 / 3;
    }
  {% elsif block.settings.aspect_ratio == 'portrait' %}
    .ai-slider-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 3 / 4;
    }
  {% elsif block.settings.aspect_ratio == '16-9' %}
    .ai-slider-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 16 / 9;
    }
  {% elsif block.settings.aspect_ratio == '9-16' %}
    .ai-slider-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 9 / 16;
    }
  {% endif %}

  .ai-slider-caption-{{ ai_gen_id }} {
    margin-top: 12px;
    margin-bottom: 0;
    font-size: 1.1rem;
    color: #000;
  }

  .ai-slider-controls-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 24px;
    max-width: 100%;
  }

  .ai-slider-arrow-{{ ai_gen_id }} {
    background: {{ block.settings.arrow_background }};
    border: 1px solid {{ block.settings.arrow_background }};
    cursor: pointer;
    padding: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
    border-radius: 50%;
  }

  .ai-slider-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    transform: scale(1.1);
  }

  .ai-slider-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-slider-arrow-{{ ai_gen_id }}:disabled:hover {
    transform: none;
  }

  .ai-slider-arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.arrow_color }};
    stroke-width: 2;
    fill: none;
  }

  /* MODIFIED: Scrollable dots */
  .ai-slider-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    align-items: center;
    overflow-x: auto;
    scroll-behavior: smooth;
    max-width: min(60vw, 570px); /* Adjust max-width dynamically */
    padding: 4px 0;
    position: relative;
    /* Hide scrollbars for clean look */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .ai-slider-dots-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-slider-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s ease;
    flex-shrink: 0; /* Prevents dot squishing */
  }

  .ai-slider-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slider-controls-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-slider-lightbox-{{ ai_gen_id }} {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: rgba(0, 0, 0, 0.9);
  }

  .ai-slider-lightbox-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-slider-lightbox-dialog-{{ ai_gen_id }} {
    position: relative;
    width: min(1100px, 100%);
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) 56px;
    gap: 16px;
    align-items: center;
  }

  .ai-slider-lightbox-stage-{{ ai_gen_id }} {
    position: relative;    
    border-radius: 16px;
    overflow: hidden;    
    touch-action: pan-y;
    cursor: grab;
  }

  .ai-slider-lightbox-stage-{{ ai_gen_id }}.dragging {
    cursor: grabbing;
  }

  .ai-slider-lightbox-image-{{ ai_gen_id }} {
    width: 100%;
    max-height: 78vh;
    object-fit: contain;
    display: block;    
    user-select: none;
    -webkit-user-drag: none;
  }

  .ai-slider-lightbox-caption-wrap-{{ ai_gen_id }} {
    padding: 16px 20px 18px;
  }

  .ai-slider-lightbox-caption-{{ ai_gen_id }} {
    margin: 0;
    color: #000;
    font-size: 1rem;
    line-height: 1.5;
  }

  .ai-slider-lightbox-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .ai-slider-lightbox-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border: none;
    padding: 0;
    border-radius: 50%;
    background: #fff;
    opacity: 0.25;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-slider-lightbox-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slider-lightbox-arrow-{{ ai_gen_id }},
  .ai-slider-lightbox-close-{{ ai_gen_id }} {
    border: none;
    background: #fff;
    color: #000;
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, opacity 0.2s ease;
    flex-shrink: 0;
  }

  .ai-slider-lightbox-arrow-{{ ai_gen_id }}:hover,
  .ai-slider-lightbox-close-{{ ai_gen_id }}:hover {
    transform: scale(1.06);
  }

  .ai-slider-lightbox-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    transform: none;
  }

  .ai-slider-lightbox-arrow-{{ ai_gen_id }} svg {
    width: 22px;
    height: 22px;
    stroke: #000;
    stroke-width: 2;
    fill: none;
  }

  .ai-slider-lightbox-close-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 3;
    line-height: 1;
  }

  .ai-slider-lightbox-close-{{ ai_gen_id }} img {
    height: 12px;
    width: 12px;
  }

  @media screen and (max-width: 767px) {
    .ai-slider-dots-{{ ai_gen_id }} {
         max-width: min(60vw, 240px);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-slider-controls-{{ ai_gen_id }} {
      gap: 12px;
      margin-top: 16px;
    }

    .ai-slider-arrow-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }

    .ai-slider-lightbox-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-slider-lightbox-dialog-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-slider-lightbox-arrow-{{ ai_gen_id }} {
      position: absolute;
      top: 45%;
      transform: translateY(-45%);
      z-index: 3;
      width: 30px;
      height: 30px;
    }

    .ai-slider-lightbox-close-{{ ai_gen_id }} {
      width: 30px;
      height: 30px;
    }

    .ai-slider-lightbox-arrow-{{ ai_gen_id }}:hover {
      transform: translateY(-50%) scale(1.04);
    }

    .ai-slider-lightbox-prev-{{ ai_gen_id }} {
      left: -8px;
    }

    .ai-slider-lightbox-next-{{ ai_gen_id }} {
      right: -8px;
    }

    .ai-slider-lightbox-image-{{ ai_gen_id }} {
      max-height: 70vh;
    }

    .ai-slider-lightbox-caption-wrap-{{ ai_gen_id }} {
      padding: 14px 16px 16px;
    }
  }
{% endstyle %}

<image-slider-{{ ai_gen_id }} class="ai-slider-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
