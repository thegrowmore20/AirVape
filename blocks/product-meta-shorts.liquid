{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign metafield_namespace = block.settings.metafield_namespace
  assign metafield_key = block.settings.metafield_key
  assign video_links = product.metafields[metafield_namespace][metafield_key].value
%}


{% if video_links != blank and video_links.size > 0 %}
  {% style %}
    .ai-video-slider-{{ ai_gen_id }} {
      display: block;
      width: {{ block.settings.desktop_width_percent }}%;
      max-width: 100%;
      margin: 0 auto;
      padding: {{ block.settings.section_padding }}px 0;
    }

    .ai-video-slider-wrapper-{{ ai_gen_id }} {
      position: relative;
      overflow: hidden;
      padding: 0 20px;
      cursor: grab;
    }

    .ai-video-slider-wrapper-{{ ai_gen_id }}.dragging {
      cursor: grabbing;
    }

    .ai-video-slider-track-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.slide_gap }}px;
      transition: transform 0.3s ease;
      user-select: none;
    }

    .ai-video-slider-track-{{ ai_gen_id }}.dragging {
      transition: none;
    }

    .ai-video-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_desktop | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_desktop }});
      position: relative;
      aspect-ratio: 9 / 16;
      border-radius: {{ block.settings.video_border_radius }}px;
      overflow: hidden;
      background-color: #000;
    }

    /* ===== Facade cover (replaces inline iframe) ===== */
    .ai-video-cover-{{ ai_gen_id }} {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      padding: 0;
      margin: 0;
      border: none;
      background-color: #000;
      cursor: pointer;
      display: block;
      overflow: hidden;
    }

    .ai-video-cover-img-{{ ai_gen_id }} {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      -webkit-user-drag: none;
      user-select: none;
      transition: transform 0.3s ease;
    }

    .ai-video-cover-{{ ai_gen_id }}:hover .ai-video-cover-img-{{ ai_gen_id }} {
      transform: scale(1.04);
    }

    .ai-video-play-{{ ai_gen_id }} {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: {{ block.settings.play_button_size }}px;
      aspect-ratio: 48 / 48;
      opacity: 0.95;
      transition: transform 0.2s ease, opacity 0.2s ease;
      pointer-events: none;
    }

    .ai-video-play-{{ ai_gen_id }} svg {
      width: 100%;
      height: 100%;
      display: block;
      filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.45));
    }

    .ai-video-cover-{{ ai_gen_id }}:hover .ai-video-play-{{ ai_gen_id }} {
      transform: translate(-50%, -50%) scale(1.08);
      opacity: 1;
    }

    .ai-video-slider-controls-{{ ai_gen_id }} {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: {{ block.settings.controls_spacing }}px;
    }

    .ai-video-slider-arrow-{{ ai_gen_id }} {
      background-color: {{ block.settings.arrow_background }};
      color: {{ block.settings.arrow_color }};
      border: 1px solid #E6E6E6;
      width: {{ block.settings.arrow_size }}px;
      height: {{ block.settings.arrow_size }}px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      flex-shrink: 0;
    }

    .ai-video-slider-arrow-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.arrow_hover_background }};
      color: {{ block.settings.arrow_hover_color }};
      transform: scale(1.1);
    }

    .ai-video-slider-arrow-{{ ai_gen_id }}:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .ai-video-slider-arrow-{{ ai_gen_id }}:disabled:hover {
      transform: none;
    }

    .ai-video-slider-dots-{{ ai_gen_id }} {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .ai-video-slider-dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size }}px;
      height: {{ block.settings.dot_size }}px;
      border-radius: 50%;
      background-color: {{ block.settings.dot_color }};
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      padding: 0;
    }

    .ai-video-slider-dot-{{ ai_gen_id }}.active {
      background-color: {{ block.settings.dot_active_color }};
    }

    .ai-video-slider-dot-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.dot_active_color }};
    }

    @media screen and (max-width: 991px) and (min-width: 768px) {
      .ai-video-slide-{{ ai_gen_id }} {
        flex: 0 0 calc((100% - ({{ block.settings.slides_medium | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_medium }});
      }
    }

    @media screen and (max-width: 767px) {
      .ai-video-slide-{{ ai_gen_id }} {
        flex: 0 0 calc((100% - ({{ block.settings.slides_mobile | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_mobile }});
      }

      .ai-video-slider-wrapper-{{ ai_gen_id }} {
        padding: 0;
      }
    }

    /* ===== Shared YouTube popup (single instance, shared classes) ===== */
    .youtube-popup-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 999999;
      padding: 20px;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s ease;
    }

    .youtube-popup-overlay.is-open {
      opacity: 1;
      visibility: visible;
    }

    .youtube-popup-content {
      position: relative;
      height: min(88vh, 92vw * 1.7778, 720px);
      aspect-ratio: 9 / 16;
    }

    .youtube-popup-frame {
      position: relative;
      width: 100%;
      height: 100%;
      background: #000;
      border-radius: 12px;
      overflow: hidden;
    }

    .youtube-popup-frame iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .youtube-popup-close {
      position: fixed;
      top: 20px;
      right: 20px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #fff;
      color: #000;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.2s ease;
      z-index: 1;
    }

    .youtube-popup-close:hover {
      transform: scale(1.1);
    }
  {% endstyle %}

  <video-slider-{{ ai_gen_id }} class="ai-video-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="ai-video-slider-wrapper-{{ ai_gen_id }}" data-wrapper>
      <div class="ai-video-slider-track-{{ ai_gen_id }}" data-track>
        {% for video_url in video_links %}
          {% liquid
            assign video_id = ''
            assign video_type = ''

            if video_url contains 'youtube.com' or video_url contains 'youtu.be'
              assign video_type = 'youtube'
              if video_url contains 'youtu.be/'
                assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
              elsif video_url contains 'watch?v='
                assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first
              elsif video_url contains 'embed/'
                assign video_id = video_url | split: 'embed/' | last | split: '?' | first
              elsif video_url contains 'shorts/'
                assign video_id = video_url | split: 'shorts/' | last | split: '?' | first
              endif
            elsif video_url contains 'vimeo.com'
              assign video_type = 'vimeo'
              assign video_id = video_url | split: 'vimeo.com/' | last | split: '/' | first | split: '?' | first
            endif
          %}

          {% if video_id != blank %}
            <div class="ai-video-slide-{{ ai_gen_id }}" data-slide>
              <button
                type="button"
                class="ai-video-cover-{{ ai_gen_id }} youtube-trigger"
                data-video-id="{{ video_id }}"
                data-video-type="{{ video_type }}"
                data-mute="{{ block.settings.muted }}"
                aria-label="Play video {{ forloop.index }}"
              >
                {% if block.settings.cover_image != blank %}
                  <img
                    class="ai-video-cover-img-{{ ai_gen_id }}"
                    src="{{ block.settings.cover_image | image_url: width: 720 }}"
                    loading="lazy"
                    draggable="false"
                    alt="Video thumbnail {{ forloop.index }}"
                  >
                {% elsif video_type == 'youtube' %}
                  <img
                    class="ai-video-cover-img-{{ ai_gen_id }} youtube-cover-img"
                    src="https://i.ytimg.com/vi/{{ video_id }}/maxresdefault.jpg"
                    onerror="if(!this.dataset.s){this.dataset.s='1';this.src='https://i.ytimg.com/vi/{{ video_id }}/hqdefault.jpg';}"
                    loading="lazy"
                    draggable="false"
                    width="720"
                    height="1280"
                    alt="Video thumbnail {{ forloop.index }}"
                  >
                {% endif %}
                <span class="ai-video-play-{{ ai_gen_id }}" aria-hidden="true">
                  <svg viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
                    <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="{{ block.settings.play_button_color }}"></path>
                    <path d="M45 24 27 14v20z" fill="#ffffff"></path>
                  </svg>
                </span>
              </button>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-video-slider-controls-{{ ai_gen_id }}" data-controls>
      {% if block.settings.show_arrows %}
        <button class="ai-video-slider-arrow-{{ ai_gen_id }}" data-prev aria-label="Previous slide">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
      {% endif %}

      {% if block.settings.show_dots %}
        <div class="ai-video-slider-dots-{{ ai_gen_id }}" data-dots></div>
      {% endif %}

      {% if block.settings.show_arrows %}
        <button class="ai-video-slider-arrow-{{ ai_gen_id }}" data-next aria-label="Next slide">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}
    </div>
  </video-slider-{{ ai_gen_id }}>

  <script>
    /* ===== Shared YouTube/Vimeo popup — built once, reused by every slide & block ===== */
    (function () {
      if (window.YTPopup) return;

      function buildPopup() {
        var existing = document.querySelector('.youtube-popup-overlay');
        if (existing) return existing;

        var overlay = document.createElement('div');
        overlay.className = 'youtube-popup-overlay';
        overlay.innerHTML =
          '<button class="youtube-popup-close" type="button" aria-label="Close video">' +
            '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
              '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>' +
            '</svg>' +
          '</button>' +
          '<div class="youtube-popup-content">' +
            '<div class="youtube-popup-frame"></div>' +
          '</div>';
        document.body.appendChild(overlay);

        var frame = overlay.querySelector('.youtube-popup-frame');

        function close() {
          overlay.classList.remove('is-open');
          document.body.style.overflow = '';
          frame.innerHTML = ''; // destroy iframe -> stops playback & frees memory
        }

        overlay.querySelector('.youtube-popup-close').addEventListener('click', close);
        overlay.addEventListener('click', function (e) {
          if (e.target === overlay) close();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && overlay.classList.contains('is-open')) close();
        });

        overlay._frame = frame;
        return overlay;
      }

      window.YTPopup = {
        open: function (type, id, opts) {
          opts = opts || {};
          if (!id) return;

          var overlay = buildPopup();
          var frame = overlay._frame;
          var src;

          if (type === 'vimeo') {
            src = 'https://player.vimeo.com/video/' + id +
              '?autoplay=1&' + (opts.mute ? 'muted=1&' : '') + 'loop=1';
          } else {
            src = 'https://www.youtube.com/embed/' + id +
              '?autoplay=1&' + (opts.mute ? 'mute=1&' : '') +
              'loop=1&playlist=' + id + '&controls=1&modestbranding=1&rel=0&playsinline=1';
          }

          var iframe = document.createElement('iframe');
          iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
          iframe.setAttribute('allowfullscreen', '');
          iframe.setAttribute('title', 'Video player');
          iframe.src = src;

          frame.innerHTML = '';
          frame.appendChild(iframe);

          overlay.classList.add('is-open');
          document.body.style.overflow = 'hidden';
        }
      };
    })();

    /* ===== Per-block slider ===== */
    (function () {
      class VideoSlider{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
          this.currentIndex = 0;
          this.isDragging = false;
          this.startPos = 0;
          this.currentTranslate = 0;
          this.prevTranslate = 0;
          this.dragStartTime = 0;
          this.hasDragged = false;
        }

        connectedCallback() {
          this.wrapper = this.querySelector('[data-wrapper]');
          this.track = this.querySelector('[data-track]');
          this.slides = this.querySelectorAll('[data-slide]');
          this.prevBtn = this.querySelector('[data-prev]');
          this.nextBtn = this.querySelector('[data-next]');
          this.dotsContainer = this.querySelector('[data-dots]');
          this.controlsContainer = this.querySelector('[data-controls]');

          // Click-to-open popup — wired regardless of whether the slider scrolls.
          this.setupTriggers();

          this.slidesPerView = this.getSlidesPerView();
          this.totalSlides = this.slides.length;
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);

          if (this.totalSlides <= this.slidesPerView) {
            if (this.controlsContainer) {
              this.controlsContainer.style.display = 'none';
            }
            return;
          }

          this.setupEventListeners();
          this.createDots();
          this.updateControls();

          window.addEventListener('resize', () => {
            this.handleResize();
          });
        }

        setupTriggers() {
          this.slides.forEach((slide) => {
            const trigger = slide.querySelector('[data-video-id]');
            if (!trigger) return;
            trigger.addEventListener('click', (e) => {
              e.preventDefault();
              if (this.hasDragged) return; // suppress click that ended a drag
              if (window.YTPopup) {
                window.YTPopup.open(trigger.dataset.videoType, trigger.dataset.videoId, {
                  mute: trigger.dataset.mute === 'true'
                });
              }
            });
          });
        }

        getSlidesPerView() {
          const width = window.innerWidth;
          if (width < 768) {
            return {{ block.settings.slides_mobile }};
          } else if (width < 992) {
            return {{ block.settings.slides_medium }};
          } else {
            return {{ block.settings.slides_desktop }};
          }
        }

        handleResize() {
          const newSlidesPerView = this.getSlidesPerView();
          if (newSlidesPerView !== this.slidesPerView) {
            this.slidesPerView = newSlidesPerView;
            this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);

            if (this.currentIndex > this.maxIndex) {
              this.currentIndex = this.maxIndex;
            }

            if (this.totalSlides <= this.slidesPerView) {
              if (this.controlsContainer) {
                this.controlsContainer.style.display = 'none';
              }
            } else {
              if (this.controlsContainer) {
                this.controlsContainer.style.display = 'flex';
              }
            }

            this.createDots();
            this.updateSlider();
          }
        }

        setupEventListeners() {
          if (this.prevBtn) {
            this.prevBtn.addEventListener('click', () => this.prev());
          }
          if (this.nextBtn) {
            this.nextBtn.addEventListener('click', () => this.next());
          }

          this.wrapper.addEventListener('mousedown', this.dragStart.bind(this));
          this.wrapper.addEventListener('touchstart', this.dragStart.bind(this), { passive: true });

          window.addEventListener('mouseup', this.dragEnd.bind(this));
          window.addEventListener('touchend', this.dragEnd.bind(this));

          window.addEventListener('mousemove', this.drag.bind(this));
          window.addEventListener('touchmove', this.drag.bind(this), { passive: false });

          // Capture-phase guard: cancel the click that follows a real drag.
          this.wrapper.addEventListener('click', (e) => {
            if (this.hasDragged) {
              e.preventDefault();
              e.stopPropagation();
            }
          }, true);
        }

        createDots() {
          if (!this.dotsContainer) return;

          this.dotsContainer.innerHTML = '';
          const dotsCount = this.maxIndex + 1;

          for (let i = 0; i < dotsCount; i++) {
            const dot = document.createElement('button');
            dot.classList.add('ai-video-slider-dot-{{ ai_gen_id }}');
            dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
            if (i === this.currentIndex) {
              dot.classList.add('active');
            }
            dot.addEventListener('click', () => this.goToSlide(i));
            this.dotsContainer.appendChild(dot);
          }
        }

        updateControls() {
          if (this.prevBtn) {
            this.prevBtn.disabled = this.currentIndex === 0;
          }
          if (this.nextBtn) {
            this.nextBtn.disabled = this.currentIndex >= this.maxIndex;
          }

          if (this.dotsContainer) {
            const dots = this.dotsContainer.querySelectorAll('.ai-video-slider-dot-{{ ai_gen_id }}');
            dots.forEach((dot, index) => {
              if (index === this.currentIndex) {
                dot.classList.add('active');
              } else {
                dot.classList.remove('active');
              }
            });
          }
        }

        updateSlider(animate = true) {
          const slideWidth = this.slides[0].offsetWidth;
          const gap = {{ block.settings.slide_gap }};
          const offset = -(this.currentIndex * (slideWidth + gap));

          if (!animate) {
            this.track.style.transition = 'none';
          }

          this.track.style.transform = `translateX(${offset}px)`;

          if (!animate) {
            this.track.offsetHeight;
            this.track.style.transition = '';
          }

          this.updateControls();
        }

        prev() {
          if (this.currentIndex > 0) {
            this.currentIndex--;
            this.updateSlider();
          }
        }

        next() {
          if (this.currentIndex < this.maxIndex) {
            this.currentIndex++;
            this.updateSlider();
          }
        }

        goToSlide(index) {
          this.currentIndex = index;
          this.updateSlider();
        }

        dragStart(event) {
          this.isDragging = true;
          this.hasDragged = false;
          this.dragStartTime = Date.now();
          this.startPos = this.getPositionX(event);
          this.track.classList.add('dragging');
          this.wrapper.classList.add('dragging');

          const slideWidth = this.slides[0].offsetWidth;
          const gap = {{ block.settings.slide_gap }};
          this.prevTranslate = -(this.currentIndex * (slideWidth + gap));
        }

        drag(event) {
          if (!this.isDragging) return;

          const currentPosition = this.getPositionX(event);
          const diff = currentPosition - this.startPos;

          if (Math.abs(diff) > 5) {
            this.hasDragged = true;
            event.preventDefault();
          }

          this.currentTranslate = this.prevTranslate + diff;
          this.track.style.transform = `translateX(${this.currentTranslate}px)`;
        }

        dragEnd() {
          if (!this.isDragging) return;

          this.isDragging = false;
          this.track.classList.remove('dragging');
          this.wrapper.classList.remove('dragging');

          const movedBy = this.currentTranslate - this.prevTranslate;
          const dragDuration = Date.now() - this.dragStartTime;
          const velocity = Math.abs(movedBy) / dragDuration;

          const threshold = velocity > 0.5 ? 30 : 100;

          if (movedBy < -threshold && this.currentIndex < this.maxIndex) {
            this.currentIndex++;
          } else if (movedBy > threshold && this.currentIndex > 0) {
            this.currentIndex--;
          }

          this.updateSlider();

          setTimeout(() => {
            this.hasDragged = false;
          }, 10);
        }

        getPositionX(event) {
          return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
        }
      }

      customElements.define('video-slider-{{ ai_gen_id }}', VideoSlider{{ ai_gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Product Shorts",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Metafield configuration"
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield key",
      "default": "product_short_videos"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Fallback cover image",
      "info": "Used for Vimeo videos and as a fallback when a YouTube thumbnail is missing. YouTube thumbnails load automatically per video."
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute videos in popup",
      "default": false
    },
    {
      "type": "range",
      "id": "play_button_size",
      "label": "Play button size",
      "min": 40,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 68
    },
    {
      "type": "color",
      "id": "play_button_color",
      "label": "Play button color",
      "default": "#FF0000"
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Video border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Slider layout"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides on desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_medium",
      "label": "Slides on medium devices",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides on mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Gap between slides",
