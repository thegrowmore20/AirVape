{% doc %}
  @prompt
    Create a product badge that displays overlaid on top of product images for products that have the tag "new". The badge should be positioned at the corner of the product image and be customizable for text, colors, size, and position. The badge should only appear when a product has the "new" tag., shopify said block generation failed
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign has_new_tag = false
  if block.settings.product
    for tag in block.settings.product.tags
      assign tag_downcase = tag | downcase
      if tag_downcase == 'new'
        assign has_new_tag = true
        break
      endif
    endfor
  endif
%}

{% if has_new_tag %}
  {% style %}
    .ai-product-badge-{{ ai_gen_id }} {
      position: absolute;
      z-index: 10;
      display: inline-block;
      padding: {{ block.settings.badge_padding }}px;
      background-color: {{ block.settings.badge_background_color }};
      color: {{ block.settings.badge_text_color }};
      font-size: {{ block.settings.badge_font_size }}px;
      font-weight: {{ block.settings.badge_font_weight }};
      text-transform: {{ block.settings.badge_text_transform }};
      border-radius: {{ block.settings.badge_border_radius }}px;
      width: {{ block.settings.desktop_width_percent }}%;
      max-width: 100%;
    }

    .ai-product-badge-{{ ai_gen_id }}--top-left {
      top: {{ block.settings.badge_offset }}px;
      left: {{ block.settings.badge_offset }}px;
    }

    .ai-product-badge-{{ ai_gen_id }}--top-right {
      top: {{ block.settings.badge_offset }}px;
      right: {{ block.settings.badge_offset }}px;
    }

    .ai-product-badge-{{ ai_gen_id }}--bottom-left {
      bottom: {{ block.settings.badge_offset }}px;
      left: {{ block.settings.badge_offset }}px;
    }

    .ai-product-badge-{{ ai_gen_id }}--bottom-right {
      bottom: {{ block.settings.badge_offset }}px;
      right: {{ block.settings.badge_offset }}px;
    }
  {% endstyle %}

  <div
    class="ai-product-badge-{{ ai_gen_id }} ai-product-badge-{{ ai_gen_id }}--{{ block.settings.badge_position }}"
    {{ block.shopify_attributes }}
  >
    {{ block.settings.badge_text }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Product badge",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "paragraph",
      "content": "Badge will only display if the product has a 'new' tag."
    },
    {
      "type": "header",
      "content": "Badge content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "NEW"
    },
    {
      "type": "header",
      "content": "Badge position"
    },
    {
      "type": "select",
      "id": "badge_position",
      "label": "Position",
      "options": [
        {
          "value": "top-left",
          "label": "Top left"
        },
        {
          "value": "top-right",
          "label": "Top right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "top-left"
    },
    {
      "type": "range",
      "id": "badge_offset",
      "label": "Offset from edge",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "header",
      "content": "Badge style"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Background color",
      "default": "#d12b23"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "badge_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "badge_text_transform",
      "label": "Text style",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "badge_padding",
      "label": "Padding",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Product badge"
    }
  ]
}
{% endschema %}