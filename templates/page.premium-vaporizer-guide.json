    "custom_liquid_Qbigrh": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "full_width": true,
        "remove_horizontal_space": false,
        "remove_vertical_space": false,
        "custom_liquid": "<div class=\"custom-glossary\">\n  <h2 class=\"glossary-title\">Glossary</h2>\n\n  <details class=\"glossary-item\">\n    <summary>Conduction Heating</summary>\n    <p>Heats material through direct contact with the chamber.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>Convection Heating</summary>\n    <p>Uses heated air to vaporize material more evenly and smoothly.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>Hybrid Heating</summary>\n    <p>Combines conduction and convection for a better balance of flavor, efficiency, and performance.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>Isolated Airpath</summary>\n    <p>Keeps the vapor path separate from internal electronics and other components.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>USB-C Charging</summary>\n    <p>A faster and more reliable charging standard used in modern devices.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>Microdosing</summary>\n    <p>Using a smaller amount of material for lighter, more controlled sessions.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>On-Demand Mode</summary>\n    <p>Activates heat only when needed, rather than maintaining it continuously.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>Session Mode</summary>\n    <p>Maintains a set temperature throughout the session.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>Dual-Use</summary>\n    <p>Designed to support both dry herb and concentrates.</p>\n  </details>\n\n  <details class=\"glossary-item\">\n    <summary>Gold-Plated Chamber</summary>\n    <p>Helps improve heat transfer while supporting clean, consistent flavor.</p>\n  </details>\n</div>\n\n<style>\n.custom-glossary {\n  max-width: 800px;\n  margin: 2rem auto;\n  font-family: inherit;\n}\n.glossary-title {\n  font-size: 1.8rem;\n  font-weight: 700;\n  margin-bottom: 1rem;\n  text-align: center;\n}\n.glossary-item {\n  border: 1px solid #e5e5e5;\n  border-radius: 6px;\n  margin-bottom: 8px;\n  overflow: hidden;\n}\n.glossary-item summary {\n  cursor: pointer;\n  font-weight: 600;\n  padding: 12px 16px;\n  background: #f9f9f9;\n  position: relative;\n}\n.glossary-item summary::-webkit-details-marker {\n  display: none;\n}\n.glossary-item summary:after {\n  content: \"+\";\n  position: absolute;\n  right: 16px;\n  top: 50%;\n  transform: translateY(-50%);\n  font-weight: bold;\n}\n.glossary-item[open] summary:after {\n  content: \"–\";\n}\n.glossary-item p {\n  margin: 0;\n  padding: 12px 16px;\n  background: #fff;\n  font-size: 0.95rem;\n  color: #333;\n}\n</style>",
        "background_color": "rgba(0,0,0,0)",
        "text_color": "#333333"
      }
    },
