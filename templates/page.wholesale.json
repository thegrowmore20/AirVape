    "rich_text_6BPfjB": {
      "type": "rich-text",
      "blocks": {
        "heading_keTGCd": {
          "type": "heading",
          "settings": {
            "heading": "Wholesale Requirements",
            "heading_size": "h3",
            "heading_html_tag": "h2"
          }
        },
        "text_qGj8yz": {
          "type": "text",
          "settings": {
            "text": "<h3><strong>Minimum Order Quantity</strong></h3><p>Minimum order quantity depends on the product type, packaging requirements, and shipping destination.</p><p>MOQ may vary by product category. Standard products may have a lower MOQ, while customized, private label, branded, or bulk production orders may require a higher minimum quantity.</p><p>Please contact us with your product details so we can confirm the exact MOQ for your request.</p><h3><strong>Pricing Structure</strong></h3><p>Wholesale pricing depends on:</p><ul><li>Product type</li><li>Order quantity</li><li>Order value</li><li>Customization requirements</li></ul><p>Larger orders typically qualify for better pricing and volume-based discounts.</p><h3><strong>Shipping and Delivery</strong></h3><p>We ship to multiple international regions, subject to shipping coverage, customs regulations, and product availability.</p><p>Estimated delivery times vary by destination and may also depend on customs clearance, order preparation time, and the shipping method selected. Exact timelines can be shared once we review your order requirements and delivery location.</p>"
          }
        }
      },
