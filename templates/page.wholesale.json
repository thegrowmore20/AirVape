    "rich_text_4PKHxx": {
      "type": "rich-text",
      "blocks": {
        "heading_CGidjm": {
          "type": "heading",
          "settings": {
            "heading": "Why Partner With AirVape?",
            "heading_size": "h3",
            "heading_html_tag": "h2"
          }
        },
        "text_jy6qeQ": {
          "type": "text",
          "settings": {
            "text": "<h3><strong>Premium Product Range</strong></h3><p>AirVape offers premium vaporizers and accessories designed for customers who value performance, portability, and quality. Our wholesale range includes popular products such as AirVape X, Legacy PRO, and selected accessories.</p><h3><strong>Competitive Wholesale Pricing</strong></h3><p>Our wholesale pricing is based on product type, order quantity, and order value, helping partners access more competitive rates as order volume increases.</p><h3><strong>Volume-Based Pricing Opportunities</strong></h3><p>Wholesale pricing is generally structured in tiers. The higher the quantity, the more competitive the pricing can become, depending on the product and order scope.</p><h3><strong>International Shipping Support</strong></h3><p>We can ship to many countries worldwide, depending on courier coverage, customs regulations, product availability, and shipping method.</p><h3><strong>Marketing Support for Approved Partners</strong></h3><p>Approved wholesale partners may receive selected marketing materials such as available product images, product descriptions, specifications, and key product information to support sales and promotion.</p>"
          }
        }
      },
      "block_order": [
        "heading_CGidjm",
        "text_jy6qeQ"
      ],
      "settings": {
        "full_width": true,
        "content_alignment": "mx-auto",
        "text_alignment": "text-left",
        "content_width": "normal",
        "background_color": "",
        "text_color": "",
        "heading_color": ""
      }
    },
    "rich_text_iKXHJF": {
      "type": "rich-text",
      "blocks": {
        "heading_UUNnhE": {
          "type": "heading",
          "settings": {
            "heading": "Who Can Apply?",
            "heading_size": "h3",
            "heading_html_tag": "h2"
          }
        },
        "text_DtFBKT": {
          "type": "text",
          "settings": {
            "text": "<p>Wholesale applications are open to qualified:</p><ul><li>Businesses</li><li>Distributors</li><li>Resellers</li><li>Retailers</li><li>Smoke shops</li><li>Other serious trade partners</li></ul><p>Individuals may also apply, but approval depends on order volume, sales channel, and business intent. Business applicants are generally preferred for long-term wholesale partnerships.</p>"
          }
        }
      },
      "block_order": [
        "heading_UUNnhE",
