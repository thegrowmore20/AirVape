display:-webkit-box;display:-ms-flexbox;display:flex;-webkit-box-orient:vertical;-webkit-box-direction:normal;-ms-flex-direction:column;flex-direction:column;color:#2a3e46;opacity:0.8;font-size:35px;text-align:right;font-weight:900;line-height:0.8}@media screen and (min-width: 778px){.upgrade-page .product-container .item .content-container .off{-webkit-box-orient:horizontal;-webkit-box-direction:normal;-ms-flex-direction:row;flex-direction:row;text-align:left}}.upgrade-page .product-container .item .content-container .off .detail{font-size:25px}@media screen and (min-width: 778px){.upgrade-page .product-container .item .content-container .off .detail{margin-left:5px}}.upgrade-page .product-container .item img{width:150px}@media screen and (min-width: 778px){.upgrade-page .product-container .item img{width:250px}}.upgrade-page .buttons{display:-webkit-box;display:-ms-flexbox;display:flex;-webkit-box-orient:vertical;-webkit-box-direction:normal;-ms-flex-direction:column;flex-direction:column;position:fixed;bottom:10px;right:15px}@media (min-width: 778px){.upgrade-page .buttons{bottom:30px;right:30px}}.upgrade-page .buttons a{background:#0f1619;color:#fff;font-size:25px;padding:10px;text-align:center;width:80px;height:80px;text-decoration:none;margin:5px 0;border-radius:100%;display:-webkit-box;display:-ms-flexbox;display:flex;-webkit-box-align:center;-ms-flex-align:center;align-items:center;-webkit-box-pack:center;-ms-flex-pack:center;justify-content:center}@media (max-width: 778px){.upgrade-page .buttons a{height:60px;width:60px}}.upgrade-page .buttons a span{font-size:20px}@media (max-width: 778px){.upgrade-page .buttons a span{font-size:15px}}.upgrade-page .buttons a img{width:100%}\n/*# sourceMappingURL=style.min.css.map */\n</style>\n\n<div class=\"upgrade-page\">\n    <h4>Choose the AirVape you own</h4>\n    <span id=\"close\" style=\"display: none;\">X</span>\n    <div class=\"product-container\">\n        <div class=\"item forth\" data-id=\"pro\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0777/8339/t/41/assets/LPROboth.png\" alt=\"\">\n            <span class=\"dot no-line\"></span>\n            <div class=\"content-container\">\n                <span class=\"name\">Legacy PRO or SP Edition</span>\n                <span class=\"off\">30%<br> OFF</span>\n            </div>\n        </div>\n        <div class=\"item third\" data-id=\"legacy\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0777/8339/t/41/assets/Legacy-manual-pic.png\" alt=\"\">\n            <span class=\"dot\"></span>\n            <div class=\"content-container\">\n                <span class=\"name\">Legacy</span>\n                <span class=\"off\">30%<br> OFF</span>\n            </div>\n        </div>\n        <div class=\"item second\" data-id=\"x\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0777/8339/t/41/assets/AVX2.png\" alt=\"\">\n            <span class=\"dot\"></span>\n            <div class=\"content-container\">\n                <span class=\"name\">AirVape X</span>\n                <span class=\"off\">50%<br> OFF</span>\n            </div>\n        </div>\n        <div class=\"item first\" data-id=\"go\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0777/8339/t/41/assets/XSgo.png\" alt=\"\">\n            <span class=\"dot\"></span>\n            <div class=\"content-container\">\n                <span class=\"name\">XS Go</span>\n                <span class=\"off\"></span>\n            </div>\n        </div>\n    </div>\n    <div class=\"buttons\">\n        <a href=\"https://airvapeusa.com/pages/upgrade-form/\">\n            <!--<img src=\"https://cdn.shopify.com/s/files/1/0777/8339/t/41/assets/experience-upgrade.svg\" alt=\"\" />-->\n            <span>Apply</span>\n        </a>\n        <a href=\"https://airvapeusa.com/pages/upgrade-info\">\n            <span>More info</span>\n        </a>\n    </div>\n</div>\n<script>\n    const state = {\n        selectedItem: null,\n        pro: {\n            off: '50%<br>OFF<span class=\"detail\"></span>'\n        },\n        legacy: {\n            off: '30%<br>OFF',\n        },\n        x: {\n            off: '50%<br>OFF',\n        },\n        go: {\n            off: '',\n        },\n    };\n\n    document.querySelectorAll('.item').forEach((item) => {\n        item.addEventListener('click', function () {\n            state.selectedItem = item.getAttribute('data-id');\n\n            if (state.selectedItem === 'pro') {\n                return;\n            }\n\n            document.querySelector('.product-container').classList.add('is-open');\n\n            switch (state.selectedItem) {\n                case 'go':\n                    state.x.off = '50%<br>OFF';\n                    state.legacy.off = '30%<br>OFF';\n                    state.pro.off = '30%<br>OFF';\n                    state.go.off = '';\n                    break;\n                case 'x':\n                    state.legacy.off = '50%<br>OFF';\n                    state.pro.off = '50%<br>OFF';\n                    state.x.off = '';\n                    state.go.off = 'no';\n                    break;\n                case 'legacy':\n                    state.pro.off = '50%<br>OFF<span class=\"detail\"></span>';\n                    state.legacy.off = '';\n                    state.x.off = 'no';\n                    state.go.off = 'no';\n                    break;\n            }\n\n            render();\n        });\n    });\n\n    document.getElementById('close').addEventListener('click', () => {\n        document.querySelector('.product-container').classList.remove('is-open');\n\n        state.selectedItem = null;\n\n        render();\n    });\n\n    function render() {\n        const items = document.querySelectorAll('.item');\n\n        items.forEach(item => item.style.display = 'flex');\n\n        items.forEach((item) => {\n            const id = item.getAttribute('data-id');\n            item.querySelector('.off').innerHTML = state[id].off;\n        });\n\n        if (state.selectedItem == null) {\n            items.forEach(item => item.style.display = 'flex');\n            document.getElementById('close').style.display = 'none';\n            return;\n        }\n\n        document.getElementById('close').style.display = 'block';\n\n        for (item in state) {\n            if (item == 'selectedItem') {\n                continue;\n            }\n\n            if (state[item].off === 'no') {\n                document.querySelector('.item[data-id=' + item + ']').style.display = 'none';\n            } else {\n                document.querySelector('.item[data-id=' + item + ']').style.display = 'flex';\n            }\n        }\n    }\n</script>",
