    "rich_text_aW93VX": {
      "type": "rich-text",
      "blocks": {
        "heading_7y66qQ": {
          "type": "heading",
          "settings": {
            "heading": "Sell AirVape Products Without Holding Inventory",
            "heading_size": "h3",
            "heading_html_tag": "h2"
          }
        },
        "text_H6cXwY": {
          "type": "text",
          "settings": {
            "text": "<p>AirVape officially supports dropshipping for <strong>approved business partners only</strong>. Our dropshipping program is designed for qualified resellers who want to market and sell AirVape products through their own sales channels while we handle fulfillment directly to the end customer.</p><p>Dropshipping access is subject to <strong>account approval, product availability, and compliance with our reseller terms</strong>.</p>"
          }
        },
        "button_M8BAyR": {
          "type": "button",
          "settings": {
            "enable_form_popup": true,
            "hulk_form_id_block": "<div style=\"margin: 0 auto;\" class=\"pxFormGenerator\" id=\"2hYTel6_YFW8geyn4J9Yxg\"></div>",
            "hulk_form_popup_class": "hulk-form-modal-custom-trigger",
            "button_text": "Apply for Dropshipping",
            "button_link": "",
            "button_style": "",
            "button_size": "text-sm md:text-base",
            "button_background_color": "",
            "button_text_color": "#ffffff"
          }
        }
      },
      "block_order": [
