    "rich_text_m6htjw": {
      "type": "rich-text",
      "blocks": {
        "heading_MCAkLH": {
          "type": "heading",
          "settings": {
            "heading": "Who Can Apply?",
            "heading_size": "h3",
            "heading_html_tag": "h2"
          }
        },
        "text_zR7Bpy": {
          "type": "text",
          "settings": {
            "text": "<p>AirVape dropshipping is available for <strong>approved business partners only</strong>.</p><p>Applications may be considered from qualified:</p><ul><li>Online stores</li><li>Resellers</li><li>Marketplace sellers</li><li>Distributors</li><li>Other business partners with relevant sales channels</li></ul><p>Approval depends on business review, product fit, sales channel suitability, and compliance with reseller terms.</p>"
          }
        }
      },
      "block_order": [
        "heading_MCAkLH",
