    "rich_text_y8CwFN": {
      "type": "rich-text",
      "blocks": {
        "heading_PAVzYY": {
          "type": "heading",
          "settings": {
            "heading": "Important Program Conditions",
            "heading_size": "h3",
            "heading_html_tag": "h2"
          }
        },
        "text_idqAmN": {
          "type": "text",
          "settings": {
            "text": "<p>To maintain a reliable and compliant dropshipping partnership, approved partners must:</p><ul><li>Market products professionally and Accurately</li><li>Follow reseller terms and brand Requirements</li><li>Submit complete and correct order details</li><li>Avoid misleading claims or unauthorized product representation</li><li>Comply with destination market rules and platform policies</li></ul><p>Dropshipping services remain subject to account status, product availability, and operational approval.</p>"
          }
        }
      },
      "block_order": [
