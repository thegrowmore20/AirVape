    "faq_accordion_FfwEcy": {
      "type": "faq-accordion",
      "blocks": {
        "faqs_6xAcnt": {
          "type": "faqs",
          "settings": {
            "quiz": "What commission do you offer?",
            "answer": "<p>We offer <strong>10% commission</strong> for affiliates, plus <strong>10% off</strong> for their audience.</p>"
          }
        },
        "faqs_XnnLfx": {
          "type": "faqs",
          "settings": {
            "quiz": "What is the commission structure?",
            "answer": "<p>Our affiliate program uses a <strong>percentage-based commission structure</strong>, not a flat-rate model.</p>"
          }
        },
        "faqs_izXMEL": {
          "type": "faqs",
          "settings": {
            "quiz": "How does the affiliate program work?",
            "answer": "<p>Our affiliate program operates through <strong>Shopify Collabs</strong> on a performance-based referral model. Approved creators and affiliates receive a unique referral link or discount code to share with their audience. When a customer makes a purchase through that link or code, the customer receives a discount and the affiliate earns a commission based on the agreed terms.</p>"
          }
        },
        "faqs_LgLXKL": {
          "type": "faqs",
          "settings": {
            "quiz": "How are sales tracked and commissions credited?",
            "answer": "<p>Sales are tracked automatically through <strong>Shopify Collabs</strong> using each affiliate’s unique referral link or discount code. When a qualifying sale is made, the commission is credited to the affiliate’s account.</p>"
          }
        },
        "faqs_HqeAie": {
          "type": "faqs",
          "settings": {
            "quiz": "Do affiliates get access to a dashboard?",
            "answer": "<p>Yes. Affiliates get access to a dashboard where they can track <strong>clicks, sales, and commissions</strong>.</p>"
          }
        },
        "faqs_3cqrXd": {
          "type": "faqs",
          "settings": {
            "quiz": "Do you use a third-party affiliate network?",
            "answer": "<p>We run our affiliate program through <strong>Shopify Collabs</strong> to onboard creators, track referrals, and manage commissions in one transparent system. We do <strong>not</strong> run the program through third-party affiliate networks like ShareASale.</p>"
          }
        },
        "faqs_8eVtmy": {
          "type": "faqs",
          "settings": {
            "quiz": "How do affiliates get paid?",
            "answer": "<p>Affiliates are paid through <strong>Shopify Collabs</strong>, typically via <strong>PayPal or bank transfer</strong>, depending on their payout setup and the platform’s payment schedule.</p>"
          }
        },
        "faqs_gAH6z9": {
          "type": "faqs",
          "settings": {
            "quiz": "Are there any rules or restrictions?",
            "answer": "<p>Yes. Affiliates must promote AirVape products in a <strong>professional, honest, and brand-safe</strong> way. Misleading claims, false advertising, spam, hate or offensive content, trademark misuse, or any activity that may harm the brand is not allowed. We reserve the right to suspend or remove any affiliate account that violates program terms.</p>"
          }
        },
        "faqs_U4FCKj": {
          "type": "faqs",
          "settings": {
            "quiz": "Are there restrictions on how affiliates can promote products?",
            "answer": "<p>Yes. Affiliates may promote through approved channels such as <strong>social media, websites, blogs, email marketing, and personal networks</strong>, as long as the promotion is ethical and compliant with platform rules. Affiliates must not use fake promises, unauthorized discount claims, spam messaging, misleading paid ads, or present themselves as official representatives of the brand unless authorized.</p>"
          }
        },
        "faqs_igVGWb": {
          "type": "faqs",
          "settings": {
            "quiz": "Are there any geographical restrictions?",
            "answer": "<p>Yes. Geographic restrictions may apply depending on <strong>product availability, shipping coverage, local laws, and platform policies</strong>. Affiliates may promote in approved regions where our products can legally and operationally be sold. Some countries or regions may be restricted due to legal, compliance, or delivery limitations.</p>"
          }
        }
      },
