<div class="custom-whatsapp-connect">
      {% if template contains 'product' %}
        {% if settings.whatsapp_connect_icon != blank %}
        <a aria-label="Chat with us" class="whatsapp-connect-image-link"
          href="https://wa.me/+1 424 789 6016?text={{ 'Hi, I have a question regarding ' | url_encode }}{{ product.title | url_encode }}{{ ' - ' | url_encode }}{{ shop.url | append: product.url | url_encode }}"
          rel="noopener" target="_blank">
          {{
            settings.whatsapp_connect_icon
            | image_url: width: 50
            | image_tag:
            width: settings.whatsapp_connect_icon.width,
            height: 50,
            widths: '40, 50, 80, 100, 200',
            loading: 'lazy',
            alt: 'Whatsapp Chat Icon',
            class: 'whatsapp-connect-image'
          }}
        </a>
        {% endif %}
      {% else %}
        {% if settings.whatsapp_connect_icon != blank %}
        <a aria-label="Chat with us" class="whatsapp-connect-image-link" 
          href="https://wa.me/+14247896016?text=Hi%2C+I+am+interested+in+AIR+VAPES" r
          el="noopener" target="_blank">
          {{
            settings.whatsapp_connect_icon
            | image_url: width: 50
            | image_tag:
            width: settings.whatsapp_connect_icon.width,
            height: 50,
            widths: '40, 50, 80, 100, 200',
            loading: 'lazy',
            alt: 'Whatsapp Chat Icon',
            class: 'whatsapp-connect-image'
          }}
        </a>
        {% endif %}
      {% endif %}
    </div>