<mega-menu-horizontal
  interaction-handler="{{ interaction_handler | default: "click" }}"
  {{ block.shopify_attributes }}
  data-block-id="{{ block.id }}"
>
  <details>
    <summary>
      <a href="{{ link.url }}" class="menu-item pb-4 -mb-4">
        {{ link.title }}
        <div class="collapse-chevron w-3 ml-2">
          {% render 'icon-chevron' %}
        </div>
      </a>
    </summary>
    <div class="mega-menu-horizontal absolute left-0 right-0 top-full overflow-hidden">
      <div class="mega-menu-horizontal__inner overflow-y-auto overscroll-y-contain border-t bg-background">
        <div class="container py-8 lg:py-12">
          <div class="col-pills-grid-{{ section.id }} flex flex-wrap gap-3">
            {%- for collection in block.settings.collections -%}
              {%- assign thumb = collection.metafields.custom.megamenu_image | default: collection.image -%}
              <a data-instant href="{{ collection.url }}" class="cpl-item flex items-center gap-3">
                <div class="cpl-img flex-shrink-0 overflow-hidden rounded-block-xs">
                  {%- if thumb -%}
                    <lqip-element class="image-loader">
                    <img
                      src="{{ thumb | image_url: width: 80 }}"
                      srcset="{{ thumb | image_url: width: 40 }} 1x, {{ thumb | image_url: width: 80 }} 2x"
                      alt="{{ collection.title | escape }}"
                      width="40"
                      height="40"
                      loading="lazy"
                    >
                    </lqip-element>
                  {%- else -%}
                    <div class="cpl-img--placeholder"></div>
                  {%- endif -%}
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="cpl-title text-sm">{{ collection.title }}</span>
                  <span class="cpl-count">({{ collection.products_count }})</span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </details>
</mega-menu-horizontal>

<style>
  /* Only properties that have no compiled utility equivalent */
  .col-pills-grid-{{ section.id }} .cpl-item {
    border: 1.5px solid #e5e5e5;
    border-radius: 10px;
    padding: 6px 16px 6px 6px;
    text-decoration: none;
    color: inherit;
    background: var(--color-background, #fff);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    will-change: transform;
  }

  .col-pills-grid-{{ section.id }} .cpl-img {
    width: 40px;
    height: 40px;
    background: var(--color-background-secondary, #f5f5f5);
  }
  .col-pills-grid-{{ section.id }} .cpl-img lqip-element {
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .col-pills-grid-{{ section.id }} .cpl-title {
    font-weight: 500;
  }
  .col-pills-grid-{{ section.id }} .cpl-count {
    font-size: 0.7rem;
    color: #888;
    font-weight: 400;
  }
  .col-pills-grid-{{ section.id }} .cpl-img img,
  .col-pills-grid-{{ section.id }} .cpl-img--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .col-pills-grid-{{ section.id }} .cpl-item {
    transition: transform 0.3s ease;
    will-change: transform;
  }
  @media (hover: hover) {
    .col-pills-grid-{{ section.id }} .cpl-item:hover{
      transform: translateY(-3px);
    }
  }
  .col-pills-grid-{{ section.id }} .cpl-img--placeholder {
    background: #e0e0e0;
  }
</style>
