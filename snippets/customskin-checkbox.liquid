{%- if product.tags contains 'custom-upload' -%}
<div id="copyright-consent-block">
  <h3>Copyright and content responsibility</h3>
  <p>Before adding this product to your cart, please confirm the following.</p>

  <label><input type="checkbox" class="cc-box">
    <span>I confirm that I <strong>own the copyright</strong> in the image, or have all necessary permissions to reproduce it on a product.</span></label>

  <label><input type="checkbox" class="cc-box">
    <span>I confirm my image does <strong>not contain third-party trademarks, logos, copyrighted characters, or celebrity likenesses</strong> I am not authorized to use.</span></label>

  <label><input type="checkbox" class="cc-box">
    <span>I accept the <a href="/pages/custom-print-terms" target="_blank">Custom Print Terms</a> and <a href="/pages/content-policy" target="_blank">Content Policy</a>, and agree to <strong>indemnify {{ shop.name }}</strong> from any claim arising from my image.</span></label>

  <p id="cc-notice" style="color:#b00020;display:none;margin-top:10px;">Please tick all three boxes to continue.</p>
</div>

<style>
  #copyright-consent-block { border:1px solid #d0d0d0; border-radius:6px; padding:16px 18px; margin:20px 0; background:#fafafa; font-size:14px; line-height:1.5; }
  #copyright-consent-block h3 { margin:0 0 6px; font-size:15px; font-weight:600; }
  #copyright-consent-block p { margin:0 0 12px; color:#555; }
  #copyright-consent-block label { display:flex; align-items:flex-start; gap:10px; margin:10px 0; cursor:pointer; }
  #copyright-consent-block input[type="checkbox"] { margin-top:3px; width:18px; height:18px; flex-shrink:0; }
  #copyright-consent-block a { text-decoration:underline; }
  .cc-blocked { opacity:0.55 !important; pointer-events:none !important; cursor:not-allowed !important; }
</style>

{% comment %} <script>
    (function(){
    var TERMS_VERSION = '1.0';

    function init(){
        var block = document.getElementById('copyright-consent-block');
        if(!block) return;
        var boxes  = block.querySelectorAll('.cc-box');
        var notice = document.getElementById('cc-notice');

        function findButtons(){
        var list = [];
        var buyNow = document.getElementById('custom-checkout-button-pdp');
        if(buyNow) list.push(buyNow);
        document.querySelectorAll('form[action*="/cart/add"] button, form[action*="/cart/add"] input[type=submit]').forEach(function(b){
            if(list.indexOf(b)===-1) list.push(b);
        });
        document.querySelectorAll('button, a').forEach(function(b){
            var t=(b.innerText||'').trim().toLowerCase();
            if((t==='add to cart'||t==='buy it now') && list.indexOf(b)===-1) list.push(b);
        });
        return list;
        }

        function allChecked(){
        for(var i=0;i<boxes.length;i++) if(!boxes[i].checked) return false;
        return true;
        }

        function apply(){
        var blocked = !allChecked();
        findButtons().forEach(function(b){
            if(blocked){ b.classList.add('cc-blocked'); b.setAttribute('disabled','disabled'); }
            else { b.classList.remove('cc-blocked'); b.removeAttribute('disabled'); }
        });
        if(!blocked) notice.style.display='none';
        }

        boxes.forEach(function(b){ b.addEventListener('change', apply); });
        apply();
        setTimeout(apply, 500);
        setTimeout(apply, 2000);

        document.addEventListener('click', function(e){
        if(allChecked()) return;
        var btns = findButtons();
        for(var i=0;i<btns.length;i++){
            if(btns[i]===e.target || btns[i].contains(e.target)){
            e.preventDefault();
            e.stopImmediatePropagation();
            notice.style.display='block';
            notice.scrollIntoView({behavior:'smooth',block:'center'});
            return;
            }
        }
        }, true);

        function stampConsentOnCart(){
        var consentProps = {
            '_consent_ownership':      'yes',
            '_consent_no_infringement':'yes',
            '_consent_terms':          'yes',
            '_consent_version':        TERMS_VERSION,
            '_consent_at':             new Date().toISOString(),
            '_consent_ua':             (navigator.userAgent||'').slice(0,200)
        };
        var productId = {{ product.id | json }};

        fetch('/cart.js', {credentials:'same-origin'})
            .then(function(r){ return r.json(); })
            .then(function(cart){
            var line = null;
            for(var i=cart.items.length-1; i>=0; i--){
                if(cart.items[i].product_id === productId){ line = cart.items[i]; break; }
            }
            if(!line) return;

            var merged = Object.assign({}, line.properties || {}, consentProps);

            return fetch('/cart/change.js', {
                method: 'POST',
                credentials: 'same-origin',
                headers: {'Content-Type':'application/json','Accept':'application/json'},
                body: JSON.stringify({ id: line.key, properties: merged })
            });
            })
            .catch(function(err){ console.warn('[consent] stamp failed', err); });
        }

        function wire(btn){
        btn.addEventListener('click', function(){
            if(!allChecked()) return;
            setTimeout(stampConsentOnCart, 400);
            setTimeout(stampConsentOnCart, 1500);
        });
        }
        findButtons().forEach(wire);
        setTimeout(function(){ findButtons().forEach(wire); }, 1500);
    }

    if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', init);
    else init();
    })();
</script> {% endcomment %}

<script>
(function(){
  var TERMS_VERSION = '1.0';

  function init(){
    var block = document.getElementById('copyright-consent-block');
    if(!block) return;
    var boxes  = block.querySelectorAll('.cc-box');
    var notice = document.getElementById('cc-notice');

    function findButtons(){
      var list = [];
      var buyNow = document.getElementById('custom-checkout-button-pdp');
      if(buyNow) list.push(buyNow);
      document.querySelectorAll('.product-info-inner form[action*="/cart/add"] button, .product-info-inner form[action*="/cart/add"] input[type=submit]').forEach(function(b){
        if(list.indexOf(b)===-1) list.push(b);
      });
      document.querySelectorAll('button, a').forEach(function(b){
        var t=(b.innerText||'').trim().toLowerCase();        
        if((t==='add to cart'||t==='buy it now') && list.indexOf(b)===-1) list.push(b);
      });
      return list;
    }

    function allChecked(){
      for(var i=0;i<boxes.length;i++) if(!boxes[i].checked) return false;
      return true;
    }

    function isImageUploaderReady(){
      var uploaderContainer = document.getElementById('ImageUploaderContainer');
      if(!uploaderContainer) return true;
      return !!uploaderContainer.querySelector('#picture-card-text-wrapper-id');
    }

    function apply(){
      var checkboxesBlocked = !allChecked();
      var buyNow = document.getElementById('custom-checkout-button-pdp');

      // Only target buttons inside .product-info-inner
      var innerButtons = [];
      document.querySelectorAll('.product-info-inner button, .product-info-inner input[type=submit]').forEach(function(b){
        if(b !== buyNow) innerButtons.push(b);
      });

      innerButtons.forEach(function(b){
        if(checkboxesBlocked){ b.classList.add('cc-blocked'); b.setAttribute('disabled','disabled'); }
        else { b.classList.remove('cc-blocked'); b.removeAttribute('disabled'); }
      });

      if(buyNow){
        var blocked = checkboxesBlocked || !isImageUploaderReady();
        if(blocked){ buyNow.classList.add('cc-blocked'); buyNow.setAttribute('disabled','disabled'); }
        else { buyNow.classList.remove('cc-blocked'); buyNow.removeAttribute('disabled'); }
      }

      if(!checkboxesBlocked) notice.style.display='none';
    }

    // --- MutationObserver wiring ---

    var uploaderObserver = null;

    function observeUploaderContainer(){
      var uploaderContainer = document.getElementById('ImageUploaderContainer');
      if(!uploaderContainer || uploaderObserver) return;

      uploaderObserver = new MutationObserver(function(){
        apply();
      });

      uploaderObserver.observe(uploaderContainer, {
        childList: true,
        subtree: true
      });
    }

    var bodyObserver = new MutationObserver(function(){
      var uploaderContainer = document.getElementById('ImageUploaderContainer');
      if(uploaderContainer && !uploaderObserver){
        observeUploaderContainer();
        apply();
      }
    });

    bodyObserver.observe(document.body, {
      childList: true,
      subtree: true
    });

    // --- end MutationObserver wiring ---

    boxes.forEach(function(b){ b.addEventListener('change', apply); });
    observeUploaderContainer();
    apply();
    setTimeout(apply, 500);
    setTimeout(apply, 2000);

    document.addEventListener('click', function(e){
      if(allChecked()) return;
      var btns = findButtons();
      for(var i=0;i<btns.length;i++){
        if(btns[i]===e.target || btns[i].contains(e.target)){
          e.preventDefault();
          e.stopImmediatePropagation();
          notice.style.display='block';
          notice.scrollIntoView({behavior:'smooth',block:'center'});
          return;
        }
      }
    }, true);

    function stampConsentOnCart(){
      var consentProps = {
        '_consent_ownership':      'yes',
        '_consent_no_infringement':'yes',
        '_consent_terms':          'yes',
        '_consent_version':        TERMS_VERSION,
        '_consent_at':             new Date().toISOString(),
        '_consent_ua':             (navigator.userAgent||'').slice(0,200)
      };
      var productId = {{ product.id | json }};

      fetch('/cart.js', {credentials:'same-origin'})
        .then(function(r){ return r.json(); })
        .then(function(cart){
          var line = null;
          for(var i=cart.items.length-1; i>=0; i--){
            if(cart.items[i].product_id === productId){ line = cart.items[i]; break; }
          }
          if(!line) return;

          var merged = Object.assign({}, line.properties || {}, consentProps);

          return fetch('/cart/change.js', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {'Content-Type':'application/json','Accept':'application/json'},
            body: JSON.stringify({ id: line.key, properties: merged })
          });
        })
        .catch(function(err){ console.warn('[consent] stamp failed', err); });
    }

    function wire(btn){
      btn.addEventListener('click', function(){
        if(!allChecked()) return;
        setTimeout(stampConsentOnCart, 400);
        setTimeout(stampConsentOnCart, 1500);
      });
    }
    findButtons().forEach(wire);
    setTimeout(function(){ findButtons().forEach(wire); }, 1500);
  }

  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

{%- endif -%}